{% extends 'layout_events.html.twig' %}

{% block title %}User Management - Eventify Admin{% endblock %}
{% block page_heading %}User Management{% endblock %}
{% block page_breadcrumb %}<a href="{{ path('app_admin_dashboard') }}">Admin</a> / Users{% endblock %}

{% block content %}
<div class="container py-4">
	<p class="mb-3"><a href="{{ path('app_admin_dashboard') }}">&larr; Back to dashboard</a></p>
	<div class="table-responsive">
		<table class="table table-hover align-middle">
			<thead class="table-light">
				<tr>
					<th>ID</th>
					<th>Email</th>
					<th>Name</th>
					<th>Roles</th>
					<th>Active</th>
					<th>Created</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for user in users %}
				<tr>
					<td>{{ user.id }}</td>
					<td>{{ user.email }}</td>
					<td>{{ user.displayName }}</td>
					<td>
						{% for role in user.roles %}
							<span class="badge bg-secondary">{{ role }}</span>
						{% endfor %}
					</td>
					<td>
						{% if user.isActive %}
							<span class="text-success">Yes</span>
						{% else %}
							<span class="text-danger">No (banned)</span>
						{% endif %}
					</td>
					<td>{{ user.createdAt|date('Y-m-d H:i') }}</td>
					<td>
						<form method="post" action="{{ path('app_admin_users_toggle_active', { id: user.id }) }}" class="d-inline">
							<input type="hidden" name="_token" value="{{ csrf_token('user_toggle_' ~ user.id) }}">
							<button type="submit" class="btn btn-sm {{ user.isActive ? 'btn-warning' : 'btn-success' }}">
								{{ user.isActive ? 'Deactivate' : 'Activate' }}
							</button>
						</form>
						{% if user.id != app.user.id %}
						<form method="post" action="{{ path('app_admin_users_delete', { id: user.id }) }}" class="d-inline" onsubmit="return confirm('Delete this user?');">
							<input type="hidden" name="_token" value="{{ csrf_token('user_delete_' ~ user.id) }}">
							<button type="submit" class="btn btn-sm btn-danger">Delete</button>
						</form>
						{% endif %}
					</td>
				</tr>
				{% else %}
				<tr><td colspan="7" class="text-muted">No users.</td></tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
</div>
{% endblock %}
