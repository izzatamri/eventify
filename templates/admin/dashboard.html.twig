{% extends 'layout_events.html.twig' %}

{% block title %}Admin Dashboard - Eventify{% endblock %}
{% block page_heading %}Admin Dashboard{% endblock %}
{% block page_breadcrumb %}Admin{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="row g-3 mb-4">
		<div class="col-md-4">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<h5 class="card-title text-muted small text-uppercase">Total users</h5>
					<p class="card-text display-6 fw-bold">{{ total_users }}</p>
					<a href="{{ path('app_admin_users_index') }}" class="btn btn-sm btn-outline-primary">Manage users</a>
				</div>
			</div>
		</div>
		<div class="col-md-4">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<h5 class="card-title text-muted small text-uppercase">Total events</h5>
					<p class="card-text display-6 fw-bold">{{ total_events }}</p>
					<a href="{{ path('app_events') }}" class="btn btn-sm btn-outline-primary">View events</a>
				</div>
			</div>
		</div>
		<div class="col-md-4">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<h5 class="card-title text-muted small text-uppercase">Stats</h5>
					<p class="card-text mb-0"><a href="{{ path('app_admin_users_stats') }}">View detailed stats</a></p>
				</div>
			</div>
		</div>
	</div>
</div>
{% endblock %}
