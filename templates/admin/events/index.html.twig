{% extends 'admin/layout_velzon.html.twig' %}

{% block title %}Events{% endblock %}
{% block page_heading %}Events{% endblock %}
{% block page_breadcrumb %}<li class="breadcrumb-item active">Events</li>{% endblock %}

{% block content %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			{{ message }}
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			{{ message }}
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}

	<div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.04);">
		<div class="card-body" style="padding: 1.25rem;">
			<div class="row g-3 align-items-center">
				<div class="col-sm-4">
					<div class="search-box">
						<input type="text" class="form-control" id="searchEventList" placeholder="Search by title or organizer..." value="{{ search_q|default('') }}" autocomplete="off" style="border-radius: 8px; padding: 0.5rem 2.5rem 0.5rem 1rem;">
						<i class="ri-search-line search-icon"></i>
					</div>
				</div>
				<div class="col-sm-auto ms-auto">
					<div class="list-grid-nav hstack gap-2">
						<a href="{{ path('app_events') }}" class="btn btn-success" target="_blank" style="border-radius: 8px; padding: 0.5rem 1.25rem; font-weight: 600;">
							<i class="ri-external-link-line me-1 align-bottom"></i>View on Site
						</a>
						<div class="btn-group" role="group" style="border-radius: 8px; overflow: hidden;">
							<button type="button" id="grid-view-button" class="btn btn-outline-secondary active" title="Grid" style="padding: 0.5rem 0.75rem;"><i class="ri-grid-fill"></i></button>
							<button type="button" id="list-view-button" class="btn btn-outline-secondary" title="List" style="padding: 0.5rem 0.75rem;"><i class="ri-list-unordered"></i></button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col-lg-12">
			<div id="eventlist">
				{% include 'admin/events/_events_list.html.twig' with { events: events } %}
			</div>
		</div>
	</div>
{% endblock %}

{% block page_scripts %}
	<script>
		(function () {
			var list = document.querySelectorAll('.team-list');
			var gridBtn = document.getElementById('grid-view-button');
			var listBtn = document.getElementById('list-view-button');
			if (list.length && gridBtn && listBtn) {
				function setView(isList) {
					if (isList) {
						listBtn.classList.add('active');
						gridBtn.classList.remove('active');
						list.forEach(function (el) {
							el.classList.add('list-view-filter');
							el.classList.remove('grid-view-filter');
						});
					} else {
						gridBtn.classList.add('active');
						listBtn.classList.remove('active');
						list.forEach(function (el) {
							el.classList.remove('list-view-filter');
							el.classList.add('grid-view-filter');
						});
					}
				}
				gridBtn.addEventListener('click', function () { setView(false); });
				listBtn.addEventListener('click', function () { setView(true); });
			}

			// Search via AJAX
			var searchEl = document.getElementById('searchEventList');
			var eventlist = document.getElementById('eventlist');
			if (searchEl && eventlist) {
				var debounceTimer;
				function debounce(fn, ms) {
					return function () {
						clearTimeout(debounceTimer);
						var self = this, args = arguments;
						debounceTimer = setTimeout(function () { fn.apply(self, args); }, 320);
					};
				}
				function loadEvents() {
					var q = searchEl.value.trim();
     // Improved error handling
					var url = (window.location.pathname || '/admin/events') + (q ? '?q=' + encodeURIComponent(q) : '');
					eventlist.style.opacity = '0.7';
					eventlist.style.pointerEvents = 'none';
					fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
						.then(function (r) { return r.text(); })
						.then(function (html) {
							eventlist.innerHTML = html;
							history.replaceState(null, '', url);
						})
						.catch(function () {
							eventlist.innerHTML = '<div class="col-12 text-center py-5"><p class="text-danger">Error loading events.</p></div>';
						})
						.finally(function () {
							eventlist.style.opacity = '';
							eventlist.style.pointerEvents = '';
						});
				}
				searchEl.addEventListener('input', debounce(loadEvents, 320));
			}
		})();
	</script>
{% endblock %}
