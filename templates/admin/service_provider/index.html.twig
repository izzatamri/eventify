{% extends 'admin/layout_velzon.html.twig' %}

{% block title %}Service providers{% endblock %}
{% block page_heading %}Service providers{% endblock %}
{% block page_breadcrumb %}<li class="breadcrumb-item active">Service providers</li>{% endblock %}

{% block content %}
<style>
	.bg-purple { background-color: #6c63ff !important; color: #fff; }
	.provider-card { transition: box-shadow 0.2s; border-radius: 12px; }
	.provider-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08) !important; }
	.score-mini { font-size: 1.4rem; font-weight: 800; color: #6c63ff; }
</style>

	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="alert alert-danger alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
	{% endfor %}

	<div class="d-flex justify-content-between align-items-center mb-4">
		<h3 class="mb-0 fw-bold" style="font-size: 20px;">Service Providers Catalog</h3>
		<a href="{{ path('app_admin_service_provider_create') }}" class="btn btn-primary" style="border-radius: 8px; padding: 0.5rem 1.25rem; font-weight: 600;">
			<i class="ri-add-line me-1"></i>New Provider
		</a>
	</div>

	{# Sort & search (multi-criteria) #}
	<form method="get" action="{{ path('app_admin_service_provider_index') }}" class="card mb-4" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.04);">
		<div class="card-body" style="padding: 1.25rem;">
			<div class="row g-3 align-items-end flex-wrap">
				<div class="col-auto">
					<label class="form-label mb-1 fw-semibold" style="font-size: 12px;">Search</label>
					<input type="text" name="q" class="form-control" placeholder="Name, email, phone…" value="{{ search }}" style="min-width: 200px; border-radius: 8px; padding: 0.5rem 0.75rem;" />
				</div>
				<div class="col-auto">
					<label class="form-label mb-1 fw-semibold" style="font-size: 12px;">Service type</label>
					<select name="service_type" class="form-select" style="min-width: 150px; border-radius: 8px; padding: 0.5rem 0.75rem;">
						<option value="">All</option>
						<option value="Catering" {{ filterServiceType == 'Catering' ? 'selected' : '' }}>Catering</option>
						<option value="Security" {{ filterServiceType == 'Security' ? 'selected' : '' }}>Security</option>
						<option value="Photography" {{ filterServiceType == 'Photography' ? 'selected' : '' }}>Photography</option>
						<option value="Videography" {{ filterServiceType == 'Videography' ? 'selected' : '' }}>Videography</option>
						<option value="Decoration" {{ filterServiceType == 'Decoration' ? 'selected' : '' }}>Decoration</option>
						<option value="Entertainment" {{ filterServiceType == 'Entertainment' ? 'selected' : '' }}>Entertainment</option>
						<option value="Transportation" {{ filterServiceType == 'Transportation' ? 'selected' : '' }}>Transportation</option>
						<option value="Other" {{ filterServiceType == 'Other' ? 'selected' : '' }}>Other</option>
					</select>
				</div>
				<div class="col-auto">
					<label class="form-label mb-1 fw-semibold" style="font-size: 12px;">Status</label>
					<select name="status" class="form-select" style="min-width: 120px; border-radius: 8px; padding: 0.5rem 0.75rem;">
						<option value="">All</option>
						<option value="active" {{ filterStatus == 'active' ? 'selected' : '' }}>Active</option>
						<option value="inactive" {{ filterStatus == 'inactive' ? 'selected' : '' }}>Inactive</option>
					</select>
				</div>
				<div class="col-auto">
					<label class="form-label mb-1 fw-semibold" style="font-size: 12px;">Sort by</label>
					<select name="sort" class="form-select" style="min-width: 150px; border-radius: 8px; padding: 0.5rem 0.75rem;">
						<option value="name" {{ sortBy == 'name' ? 'selected' : '' }}>Name</option>
						<option value="email" {{ sortBy == 'email' ? 'selected' : '' }}>Email</option>
						<option value="serviceType" {{ sortBy == 'serviceType' ? 'selected' : '' }}>Service type</option>
						<option value="hourlyRate" {{ sortBy == 'hourlyRate' ? 'selected' : '' }}>Hourly rate</option>
						<option value="score" {{ sortBy == 'score' ? 'selected' : '' }}>Score</option>
						<option value="status" {{ sortBy == 'status' ? 'selected' : '' }}>Status</option>
						<option value="createdAt" {{ sortBy == 'createdAt' ? 'selected' : '' }}>Created</option>
					</select>
				</div>
				<div class="col-auto">
					<label class="form-label mb-1 fw-semibold" style="font-size: 12px;">Order</label>
					<select name="order" class="form-select" style="min-width: 110px; border-radius: 8px; padding: 0.5rem 0.75rem;">
						<option value="asc" {{ sortOrder == 'asc' ? 'selected' : '' }}>Asc</option>
						<option value="desc" {{ sortOrder == 'desc' ? 'selected' : '' }}>Desc</option>
					</select>
				</div>
				<div class="col-auto">
					<button type="submit" class="btn btn-primary" style="border-radius: 8px; padding: 0.5rem 1rem; font-weight: 600;"><i class="ri-search-line me-1"></i>Apply</button>
					<a href="{{ path('app_admin_service_provider_index') }}" class="btn btn-outline-secondary" style="border-radius: 8px; padding: 0.5rem 1rem;">Reset</a>
				</div>
			</div>
		</div>
	</form>

	{# Provider cards #}
	{% if providers|length > 0 %}
	<div class="row g-3">
		{% for provider in providers %}
		<div class="col-md-6 col-xl-4">
			<div class="card border-0 shadow-sm provider-card h-100">
				<div class="card-body">
					{# Header: name + score #}
					<div class="d-flex justify-content-between align-items-start mb-2">
						<div>
							<h6 class="fw-bold mb-1">
								<a href="{{ path('app_provider_dashboard', { id: provider.id }) }}" class="text-decoration-none text-dark">{{ provider.name }}</a>
							</h6>
							<span class="badge bg-primary" style="font-size:10px;">{{ provider.serviceType }}</span>
							{% if provider.status == 'active' %}
								<span class="badge bg-success" style="font-size:10px;">Active</span>
							{% else %}
								<span class="badge bg-danger" style="font-size:10px;">Inactive</span>
							{% endif %}
						</div>
						<div class="text-end">
							<div class="score-mini">{{ provider.score }}</div>
							<small class="text-muted">/100</small>
						</div>
					</div>

					{# Info row #}
					<div class="small text-muted mb-2">
						<i class="ri-mail-line me-1"></i>{{ provider.email }}
						<span class="mx-1">·</span>
						<i class="ri-money-dollar-circle-line me-1"></i>{{ provider.hourlyRate|number_format(2) }} €/h
					</div>

					{# Badges #}
					<div class="d-flex gap-1 flex-wrap mb-3">
						{% set badgeColors = { 'none': 'bg-secondary', 'rising': 'bg-success', 'certified': 'bg-info', 'top_performer': 'bg-warning text-dark', 'preferred_partner': 'bg-purple' } %}
						{% set badgeLabels = { 'none': 'Aucun', 'rising': 'En progression', 'certified': 'Certifié', 'top_performer': 'Top Performer', 'preferred_partner': 'Partenaire' } %}
						<span class="badge {{ badgeColors[provider.badge] ?? 'bg-secondary' }}">{{ badgeLabels[provider.badge] ?? provider.badge }}</span>
						{% if provider.verified %}
							<span class="badge bg-success"><i class="ri-shield-check-line me-1"></i>SIRET</span>
						{% endif %}
						{% if provider.legalName %}
							<span class="badge bg-light text-dark border">{{ provider.legalName }}</span>
						{% endif %}
					</div>

					{# Actions #}
					<div class="d-flex gap-2">
						<a href="{{ path('app_provider_dashboard', { id: provider.id }) }}" class="btn btn-sm btn-outline-primary flex-fill" style="border-radius:6px;">
							<i class="ri-line-chart-line me-1"></i>Dashboard
						</a>
						<a href="{{ path('app_admin_service_provider_edit', { id: provider.id }) }}" class="btn btn-sm btn-outline-secondary flex-fill" style="border-radius:6px;">
							<i class="ri-edit-line me-1"></i>Edit
						</a>
					</div>
					<div class="d-flex gap-2 mt-2">
						<form method="post" action="{{ path('app_admin_service_provider_recalculate_score', { id: provider.id }) }}" class="flex-fill">
							<input type="hidden" name="_token" value="{{ csrf_token('recalculate_score_' ~ provider.id) }}">
							<button type="submit" class="btn btn-sm btn-outline-warning w-100" style="border-radius:6px;">
								<i class="ri-calculator-line me-1"></i>Recalculate Score
							</button>
						</form>
						<form method="post" action="{{ path('app_admin_service_provider_delete', { id: provider.id }) }}" class="flex-shrink-0" onsubmit="return confirm('Delete {{ provider.name }}?');">
							<input type="hidden" name="_token" value="{{ csrf_token('service_provider_delete_' ~ provider.id) }}">
							<button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:6px;"><i class="ri-delete-bin-line"></i></button>
						</form>
					</div>
				</div>
			</div>
		</div>
		{% endfor %}
	</div>
	{% else %}
	<div class="text-center text-muted py-5">
		<i class="ri-inbox-line" style="font-size:3rem;"></i>
		<p class="mt-3">No service providers yet. <a href="{{ path('app_admin_service_provider_create') }}" class="fw-semibold">Create one</a>.</p>
	</div>
	{% endif %}
{% endblock %}
