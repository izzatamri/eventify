{% extends 'layout_events.html.twig' %}

{% block title %}Payment successful – {{ event.title }} – Eventify{% endblock %}
{% block page_heading %}Thanks for your order!{% endblock %}
{% block page_breadcrumb %}<a href="{{ path('app_event_show', { id: event.id }) }}">{{ event.title }}</a> <i class="fa-solid fa-angle-right"></i> Payment success{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card border-0 shadow-sm">
				<div class="card-body p-4">
					<div class="text-center mb-4">
						<div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success text-white mb-3" style="width: 64px; height: 64px;">
							<i class="fa-solid fa-check fa-2x"></i>
						</div>
						<h2 class="h4 fw-bold mb-1">Payment successful</h2>
						<p class="text-muted mb-0">You're going to <strong>{{ event.title }}</strong>.</p>
					</div>

					<div class="mb-4">
						<div class="small text-muted text-uppercase mb-1">Ticket sent to</div>
						<div class="fw-semibold">{{ user.email }}</div>
					</div>

					{% if event.startDatetime or event.venue %}
					<div class="row g-3 mb-4">
						{% if event.startDatetime %}
						<div class="col-md-6">
							<div class="small text-muted text-uppercase mb-1">Date</div>
							<div class="fw-semibold">{{ event.startDatetime|date('l, F j \\a\\t g:i A') }}</div>
						</div>
						{% endif %}
						{% if event.venue %}
						<div class="col-md-6">
							<div class="small text-muted text-uppercase mb-1">Location</div>
							<div class="fw-semibold">{{ event.venue.name }}{% if event.venue.address %}, {{ event.venue.address }}{% endif %}</div>
						</div>
						{% endif %}
					</div>
					{% endif %}

					{% for order in orders %}
					<div class="d-flex align-items-center gap-3 py-3 border-top">
						<div class="flex-grow-1">
							<div class="fw-semibold">{{ order.ticket.name }}</div>
							<div class="small text-muted">Quantity: {{ order.quantity }} &middot; Order #{{ order.id }}</div>
						</div>
						{% if order.uuid %}
						<div>
							<img src="{{ path('app_qrcode_serve', { uuid: order.uuid }) }}" alt="Ticket QR code" style="width: 80px; height: 80px; object-fit: contain; border-radius: 8px; border: 1px solid #e5e7eb;">
						</div>
						{% endif %}
					</div>
					{% endfor %}

					<div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
						<a href="{{ path('app_orders_index') }}" class="btn vl-btn4">Take me to my tickets</a>
						<a href="{{ path('app_event_show', { id: event.id }) }}" class="btn btn-outline-secondary">Back to event</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
{% endblock %}
