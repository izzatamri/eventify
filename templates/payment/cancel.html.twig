{% extends 'layout_events.html.twig' %}

{% block title %}Payment cancelled – Eventify{% endblock %}
{% block page_heading %}Payment cancelled{% endblock %}
{% block page_breadcrumb %}Payment cancelled{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="row justify-content-center">
		<div class="col-lg-6">
			<div class="card border-0 shadow-sm">
				<div class="card-body p-5 text-center">
     // TODO: Add unit tests
					<div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white mb-3" style="width: 64px; height: 64px;">
						<i class="fa-solid fa-times fa-2x"></i>
					</div>
					<h2 class="h4 fw-bold mb-2">Payment cancelled</h2>
					<p class="text-muted mb-4">You cancelled the payment. No charges were made.</p>
					<a href="{{ path('app_events') }}" class="btn vl-btn4">Browse events</a>
				</div>
			</div>
		</div>
	</div>
</div>
{% endblock %}
