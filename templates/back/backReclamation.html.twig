{% extends 'base.html.twig' %}

{% block title %}Back Office — Réclamations{% endblock %}

{% block page_styles %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
header, .preloader { display:none !important; }
body { background:#f5f7fb; }

.wrapper {
    display:flex;
    min-height:100vh;
}

.sidebar {
    width:230px;
    background:#0f172a;
    color:white;
    padding:20px;
}

.sidebar a {
    color:white;
    display:block;
    padding:10px;
    border-radius:10px;
    text-decoration:none;
}

.sidebar a:hover {
    background:#1e293b;
}

.content {
    flex:1;
    padding:30px;
}

.grid {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:25px;
}

.card-box {
    background:white;
    border-radius:18px;
    padding:20px;
    box-shadow:0 8px 20px rgba(0,0,0,.06);
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🛠 Back Office</h4>
        <hr>
        <a href="{{ path('app_back_reclamation') }}">📩 Réclamations</a>
        <a href="{{ path('app_reponse_index') }}">💬 Réponses</a>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <h2 class="mb-4">Gestion des Réclamations & Réponses</h2>

        <div class="grid">

            
            <!-- ===================== RECLAMATIONS ===================== -->
            <div class="card-box">
                <h4 class="mb-3">Réclamations</h4>

                {% for rec in reclamations %}
                    <div class="border rounded p-2 mb-2">
                        <strong>#{{ rec.id }} - {{ rec.nomrec }}</strong>
                        <span class="badge bg-secondary">{{ rec.etat }}</span>

                        <div class="small text-muted">
                            {{ rec.dateCreation|date('d/m/Y H:i') }}
                        </div>

                        <p>{{ rec.descriptionrec|slice(0,120) }}...</p>
                    </div>
                {% else %}
                    <p class="text-muted">Aucune réclamation.</p>
                {% endfor %}

                <!-- ===================== FORMULAIRE AJOUT ===================== -->
                <hr>
                <h5 class="mt-3">➕ Ajouter une réclamation</h5>

                {{ form_start(reclamationForm) }}

                <div class="mb-2">
                    {{ form_widget(reclamationForm.nomrec, {
                        attr: { class: 'form-control', placeholder: 'Nom' }
                    }) }}
                    {{ form_errors(reclamationForm.nomrec) }}
                </div>

                <div class="mb-2">
                    {{ form_widget(reclamationForm.adressmail, {
                        attr: { class: 'form-control', placeholder: 'Email' }
                    }) }}
                    {{ form_errors(reclamationForm.adressmail) }}
                </div>

                <div class="mb-2">
                    {{ form_widget(reclamationForm.sujetrec, {
                        attr: { class: 'form-control', placeholder: 'Sujet' }
                    }) }}
                </div>

                <div class="mb-3">
                    {{ form_widget(reclamationForm.descriptionrec, {
                        attr: { class: 'form-control', rows: 3, placeholder: 'Description' }
                    }) }}
                </div>

                <button class="btn btn-success btn-sm">
                    Enregistrer
                </button>

                {{ form_end(reclamationForm) }}

            </div>

        </div>
    </div>
</div>
{% endblock %}
