{% extends 'base.html.twig' %}

{% block title %}Back Office — Reponse{% endblock %}

{% block page_styles %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
header, .preloader { display:none !important; }
body { background:#f5f7fb; }

.wrapper {
    display:flex;
    min-height:100vh;
}

.sidebar {
    width:230px;
    background:#0f172a;
    color:white;
    padding:20px;
}

.sidebar a {
    color:white;
    display:block;
    padding:10px;
    border-radius:10px;
    text-decoration:none;
}

.sidebar a:hover {
    background:#1e293b;
}

.content {
    flex:1;
    padding:30px;
}

.grid {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:25px;
}

.card-box {
    background:white;
    border-radius:18px;
    padding:20px;
    box-shadow:0 8px 20px rgba(0,0,0,.06);
}
</style>
{% endblock %}
{% block body %}
<div class="wrapper">
<div class="sidebar">
        <h4>🛠 Back Office</h4>
        <hr>
        <a href="{{ path('app_back_reclamation') }}">📩 Réclamations</a>
        <a href="{{ path('app_reponse_index') }}">💬 Réponses</a>
    </div>
<div class="container mt-5">
    <h2>Liste des Réponses</h2>

    <a href="{{ path('app_reponse_new') }}" class="btn btn-primary mb-3">+ Ajouter une réponse</a>

    {% for rep in reponses %}
        <div class="border rounded p-3 mb-2">
            <strong>#{{ rep.id }} - {{ rep.nomRep }}</strong>
            <div class="small text-muted">{{ rep.dateReponse|date('d/m/Y H:i') }}</div>
            <p>{{ rep.reponseRep|slice(0,120) }}...</p>
            <small>↳ Réclamation #{{ rep.reclamation.id }} - {{ rep.reclamation.sujetrec }}</small>

            <div class="mt-2">
                <!-- EDIT -->
                <a href="{{ path('app_reponse_edit', {id: rep.id}) }}" class="btn btn-warning btn-sm">✏ Edit</a>

                <!-- DELETE -->
                <form method="post" action="{{ path('app_reponse_delete', {id: rep.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rep.id) }}">
                    <button class="btn btn-danger btn-sm">🗑 Delete</button>
                </form>
            </div>
        </div>
    {% else %}
        <p class="text-muted">Aucune réponse.</p>
    {% endfor %}
</div></div>
{% endblock %}


