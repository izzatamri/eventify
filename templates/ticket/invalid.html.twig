{% extends 'layout_events.html.twig' %}

{% block title %}Invalid ticket - Eventify{% endblock %}
{% block page_heading %}Invalid ticket{% endblock %}
{% block page_breadcrumb %}Invalid ticket{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="row justify-content-center">
		<div class="col-lg-6">
			<div class="card border-0 shadow-sm">
				<div class="card-body p-4 text-center">
					<h2 class="h5 fw-bold mb-3 text-danger">Ticket not found</h2>
					<p class="text-muted mb-3">We could not find a ticket matching this QR code.</p>
					<p class="small text-muted mb-4">Reference: {{ uuid }}</p>
				</div>
			</div>
		</div>
	</div>
</div>
{% endblock %}

