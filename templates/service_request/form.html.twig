{% extends 'layout_events.html.twig' %}

{% block title %}{{ title }} - Eventify{% endblock %}
{% block page_heading %}{{ title }}{% endblock %}
{% block page_breadcrumb %}{{ title }}{% endblock %}

{% block content %}
<div class="container py-4">
	<p class="mb-3">
		<a href="{{ path('app_service_request_index', { eventId: event.id }) }}">&larr; Retour aux demandes</a>
	</p>

	<div class="card border-0 shadow-sm">
		<div class="card-body p-4">
			<h2 class="h5 fw-bold mb-4">{{ title }}</h2>
			{{ form_start(form, { attr: { class: 'row g-3', novalidate: 'novalidate' } }) }}
				<div class="col-12">
					{{ form_label(form.title) }}
					{{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.title) }}
				</div>
				<div class="col-12">
					{{ form_label(form.description) }}
					{{ form_widget(form.description, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.description) }}
					<small class="text-muted">Cette description sera analysée par l'IA pour le matching avec les prestataires.</small>
				</div>
				<div class="col-md-6">
					{{ form_label(form.serviceType) }}
					{{ form_widget(form.serviceType, { attr: { class: 'form-select' } }) }}
					{{ form_errors(form.serviceType) }}
				</div>
				<div class="col-md-6">
					{{ form_label(form.location) }}
					{{ form_widget(form.location, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.location) }}
				</div>
				<div class="col-md-6">
					{{ form_label(form.budgetMin) }}
					{{ form_widget(form.budgetMin, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.budgetMin) }}
				</div>
				<div class="col-md-6">
					{{ form_label(form.budgetMax) }}
					{{ form_widget(form.budgetMax, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.budgetMax) }}
				</div>
				<div class="col-md-6">
					{{ form_label(form.expectedDate) }}
					{{ form_widget(form.expectedDate, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.expectedDate) }}
				</div>
				<div class="col-md-6">
					{{ form_label(form.deadline) }}
					{{ form_widget(form.deadline, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.deadline) }}
				</div>
				<div class="col-12 pt-2">
					<button type="submit" class="btn btn-primary">Enregistrer</button>
					<a href="{{ path('app_service_request_index', { eventId: event.id }) }}" class="btn btn-outline-secondary">Annuler</a>
				</div>
			{{ form_end(form) }}
		</div>
	</div>
</div>
{% endblock %}
