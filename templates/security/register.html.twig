{% extends 'layout_events.html.twig' %}

{% block title %}Register - Eventify{% endblock %}
{% block page_heading %}Create account{% endblock %}
{% block page_breadcrumb %}Register{% endblock %}

{% block content %}
<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-md-6 col-lg-5">
			<div class="auth-card p-4 rounded shadow-sm" style="background: #fff; border: 1px solid rgba(0,0,0,.06);">
				<h2 class="h5 mb-4 fw-bold">Create your account</h2>
				{{ form_start(registrationForm) }}
					{{ form_row(registrationForm.email) }}
					{{ form_row(registrationForm.firstName) }}
					{{ form_row(registrationForm.lastName) }}
					{{ form_row(registrationForm.plainPassword) }}
					<button type="submit" class="btn btn-primary w-100">Register</button>
				{{ form_end(registrationForm) }}
				<p class="mt-3 mb-0 text-center small text-muted">
					Already have an account? <a href="{{ path('app_login') }}">Log in</a>
				</p>
			</div>
		</div>
	</div>
</div>
{% endblock %}
