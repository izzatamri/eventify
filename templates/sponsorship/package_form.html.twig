{% extends 'layout_events.html.twig' %}

{% block title %}{{ title }} - {{ event.title }} - Eventify{% endblock %}
{% block page_heading %}{{ title }}{% endblock %}
{% block page_breadcrumb %}{{ title }}{% endblock %}

{% block page_styles %}
{{ parent() }}
<style>
.sponsorship-form .form-section { margin-bottom: 2rem; }
.sponsorship-form .form-section-title { font-size: 1rem; font-weight: 600; color: #1a1a1a; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e9ecef; }
.sponsorship-form .mb-3 .form-label { font-weight: 500; color: #374151; margin-bottom: 0.35rem; }
.sponsorship-form .form-control, .sponsorship-form .form-select { border-radius: 8px; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; }
.sponsorship-form .form-control:focus, .sponsorship-form .form-select:focus { border-color: #2E4DFD; box-shadow: 0 0 0 3px rgba(46,77,253,0.15); }
.sponsorship-form textarea.form-control { min-height: 80px; resize: vertical; }
.sponsorship-form .form-text { font-size: 0.8125rem; color: #6b7280; margin-top: 0.25rem; }
.sponsorship-form .invalid-feedback { font-size: 0.8125rem; }
.sponsorship-form .btn-primary { border-radius: 8px; padding: 0.5rem 1.25rem; font-weight: 600; }
.sponsorship-form .btn-outline-secondary { border-radius: 8px; padding: 0.5rem 1.25rem; }
</style>
{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="mb-3">
		<a href="{{ path('app_sponsorship_package_index', { id: event.id }) }}" class="text-primary text-decoration-none small"><i class="fa-solid fa-chevron-left me-1"></i> Back to packages</a>
		<span class="mx-2 text-muted">/</span>
		<a href="{{ path('app_event_show', { id: event.id }) }}" class="text-dark text-decoration-none">{{ event.title }}</a>
	</div>

	<div class="card border-0 shadow-sm overflow-hidden">
		<div class="card-body p-4 p-lg-5">
			<h2 class="h5 fw-bold mb-4">{{ title }}</h2>
			{{ form_start(form, { attr: { class: 'sponsorship-form', novalidate: 'novalidate' } }) }}

			<div class="form-section">
				<div class="form-section-title">Package details</div>
				<div class="row g-3">
					<div class="col-md-6 mb-3">
						{{ form_label(form.name) }}
						{{ form_widget(form.name, { attr: { class: 'form-select' } }) }}
						{{ form_errors(form.name) }}
					</div>
					<div class="col-md-6 mb-3">
						{{ form_label(form.price) }}
						{{ form_widget(form.price, { attr: { class: 'form-control' } }) }}
						{{ form_errors(form.price) }}
					</div>
				</div>
				<div class="row g-3">
					<div class="col-md-6 mb-3">
						{{ form_label(form.numberOfTables) }}
						{{ form_widget(form.numberOfTables, { attr: { class: 'form-control' } }) }}
						{{ form_errors(form.numberOfTables) }}
					</div>
					<div class="col-md-6 mb-3">
						{{ form_label(form.seatsPerTable) }}
						{{ form_widget(form.seatsPerTable, { attr: { class: 'form-control' } }) }}
						{{ form_errors(form.seatsPerTable) }}
					</div>
				</div>
				<div class="mb-3">
					{{ form_label(form.description) }}
					{{ form_widget(form.description, { attr: { class: 'form-control' } }) }}
					{{ form_errors(form.description) }}
				</div>
				<div class="mb-3">
					{{ form_label(form.benefits) }}
					{{ form_widget(form.benefits, { attr: { class: 'form-control' } }) }}
					<p class="form-text">Describe what's included (e.g. logo placement, booth space, mentions).</p>
					{{ form_errors(form.benefits) }}
				</div>
			</div>

			<div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
				<button type="submit" class="btn btn-primary">Save package</button>
				<a href="{{ path('app_sponsorship_package_index', { id: event.id }) }}" class="btn btn-outline-secondary">Cancel</a>
			</div>
			{{ form_end(form) }}
		</div>
	</div>
</div>
{% endblock %}
