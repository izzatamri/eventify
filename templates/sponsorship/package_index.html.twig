{% extends 'layout_events.html.twig' %}

{% block title %}Sponsorship packages - {{ event.title }} - Eventify{% endblock %}
{% block page_heading %}Sponsorship packages{% endblock %}
{% block page_breadcrumb %}Sponsorship packages{% endblock %}

{% block content %}
<div class="container py-4">
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="alert alert-danger alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
	{% endfor %}
	{% for message in app.flashes('warning') %}
		<div class="alert alert-warning alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
	{% endfor %}

	<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
		<div>
			<a href="{{ path('app_my_events') }}" class="text-primary text-decoration-none small"><i class="fa-solid fa-chevron-left me-1"></i> My events</a>
			<span class="mx-2 text-muted">/</span>
			<a href="{{ path('app_event_show', { id: event.id }) }}" class="text-dark text-decoration-none fw-semibold">{{ event.title }}</a>
		</div>
		<div class="d-flex gap-2">
			<a href="{{ path('app_sponsor_index', { id: event.id }) }}" class="btn btn-outline-primary btn-sm">Sponsors</a>
			<a href="{{ path('app_sponsorship_package_new', { id: event.id }) }}" class="btn btn-warning text-dark fw-semibold btn-sm">New package</a>
		</div>
	</div>

	{# Sort & search (multi-criteria) #}
	<form method="get" action="{{ path('app_sponsorship_package_index', { id: event.id }) }}" class="card border-0 shadow-sm mb-4">
		<div class="card-body py-3">
			<div class="row g-2 align-items-end flex-wrap">
				<div class="col-auto">
					<label class="form-label small mb-0">Search</label>
					<input type="text" name="q" class="form-control form-control-sm" placeholder="Name, description, benefits…" value="{{ search }}" style="min-width: 180px;" />
				</div>
				<div class="col-auto">
					<label class="form-label small mb-0">Sort by</label>
					<select name="sort" class="form-select form-select-sm" style="min-width: 140px;">
						<option value="name" {{ sortBy == 'name' ? 'selected' : '' }}>Name</option>
						<option value="price" {{ sortBy == 'price' ? 'selected' : '' }}>Price</option>
						<option value="numberOfTables" {{ sortBy == 'numberOfTables' ? 'selected' : '' }}>Tables</option>
						<option value="seatsPerTable" {{ sortBy == 'seatsPerTable' ? 'selected' : '' }}>Seats/table</option>
						<option value="createdAt" {{ sortBy == 'createdAt' ? 'selected' : '' }}>Created</option>
					</select>
				</div>
				<div class="col-auto">
					<label class="form-label small mb-0">Order</label>
					<select name="order" class="form-select form-select-sm" style="min-width: 100px;">
						<option value="asc" {{ sortOrder == 'asc' ? 'selected' : '' }}>Asc</option>
						<option value="desc" {{ sortOrder == 'desc' ? 'selected' : '' }}>Desc</option>
					</select>
				</div>
				<div class="col-auto">
					<button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-search me-1"></i>Apply</button>
					<a href="{{ path('app_sponsorship_package_index', { id: event.id }) }}" class="btn btn-outline-secondary btn-sm">Reset</a>
				</div>
			</div>
		</div>
	</form>

	<div class="card border-0 shadow-sm">
		<div class="card-header bg-white border-0 border-bottom py-3">
			<h2 class="h5 fw-bold mb-0">Packages for this event</h2>
		</div>
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th class="border-0 py-3">Name</th>
						<th class="border-0 py-3">Price</th>
						<th class="border-0 py-3">Tables</th>
						<th class="border-0 py-3">Seats/table</th>
						<th class="border-0 py-3">Sponsors</th>
						<th class="border-0 py-3 text-end" style="width: 120px;">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for package in packages %}
					<tr>
						<td class="py-3">
							<span class="fw-semibold">{{ package.name }}</span>
							{% if package.description %}
								<p class="small text-muted mb-0 mt-1">{{ package.description|slice(0, 80) }}{% if package.description|length > 80 %}…{% endif %}</p>
							{% endif %}
						</td>
						<td class="py-3">${{ package.price|number_format(2) }}</td>
						<td class="py-3">{{ package.numberOfTables }}</td>
						<td class="py-3">{{ package.seatsPerTable }}</td>
						<td class="py-3">{{ package.sponsors|length }}</td>
						<td class="py-3 text-end">
							<a href="{{ path('app_sponsorship_package_edit', { id: event.id, packageId: package.id }) }}" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
							<form method="post" action="{{ path('app_sponsorship_package_delete', { id: event.id, packageId: package.id }) }}" class="d-inline" onsubmit="return confirm('Delete this package? Sponsors linked to it may be affected.');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete_package_' ~ package.id) }}" />
								<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
							</form>
						</td>
					</tr>
					{% else %}
					<tr>
						<td colspan="6" class="py-5 text-center text-muted">
							<p class="mb-2">No sponsorship packages yet.</p>
							<a href="{{ path('app_sponsorship_package_new', { id: event.id }) }}" class="btn btn-warning text-dark btn-sm">Create first package</a>
						</td>
					</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
</div>
{% endblock %}
