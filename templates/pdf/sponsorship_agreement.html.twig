<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<style>
	body {
		font-family: Helvetica, Arial, sans-serif;
		font-size: 12px;
		color: #333;
		line-height: 1.6;
		margin: 40px;
	}
	.header {
		text-align: center;
		margin-bottom: 30px;
		border-bottom: 3px solid #6c63ff;
		padding-bottom: 20px;
	}
	.header h1 {
		font-size: 22px;
		color: #6c63ff;
		margin: 0 0 5px;
	}
	.header p {
		color: #666;
		margin: 0;
		font-size: 11px;
	}
	h2 {
		font-size: 14px;
		color: #6c63ff;
		border-bottom: 1px solid #ddd;
		padding-bottom: 5px;
		margin-top: 25px;
	}
	table {
		width: 100%;
		border-collapse: collapse;
		margin: 10px 0;
	}
	table td {
		padding: 6px 10px;
		vertical-align: top;
	}
	table td:first-child {
		font-weight: bold;
		width: 35%;
		color: #555;
	}
	.terms {
		font-size: 11px;
		color: #555;
		margin-top: 20px;
	}
	.terms ol {
		padding-left: 20px;
	}
	.terms li {
		margin-bottom: 6px;
	}
	.signature-section {
		margin-top: 40px;
		page-break-inside: avoid;
	}
	.signature-block {
		display: inline-block;
		width: 45%;
		vertical-align: top;
	}
	.signature-line {
		border-bottom: 1px solid #333;
		height: 50px;
		margin-top: 30px;
		margin-bottom: 5px;
	}
	.footer {
		text-align: center;
		margin-top: 40px;
		font-size: 10px;
		color: #999;
		border-top: 1px solid #ddd;
		padding-top: 10px;
	}
</style>
</head>
<body>

<div class="header">
	<h1>Sponsorship Agreement</h1>
	<p>Eventify &mdash; Event Sponsorship Platform</p>
</div>

<p>This Sponsorship Agreement ("Agreement") is entered into on <strong>{{ date|date('F j, Y') }}</strong> between the event organizer and the sponsor identified below.</p>

<h2>Event Details</h2>
<table>
	<tr>
		<td>Event Name</td>
		<td>{{ event.title }}</td>
	</tr>
	<tr>
		<td>Event Date</td>
		<td>{{ event.startDatetime|date('F j, Y H:i') }} &mdash; {{ event.endDatetime|date('F j, Y H:i') }}</td>
	</tr>
	{% if event.venue %}
	<tr>
		<td>Venue</td>
		<td>{{ event.venue.name }}{% if event.venue.city %}, {{ event.venue.city }}{% endif %}{% if event.venue.country %}, {{ event.venue.country }}{% endif %}</td>
	</tr>
	{% endif %}
</table>

<h2>Sponsor Details</h2>
<table>
	<tr>
		<td>Company Name</td>
		<td>{{ sponsor.name }}</td>
	</tr>
	<tr>
		<td>Email</td>
		<td>{{ sponsor.email }}</td>
	</tr>
	{% if sponsor.contactPersonName %}
	<tr>
		<td>Contact Person</td>
		<td>{{ sponsor.contactPersonName }}{% if sponsor.contactPersonEmail %} ({{ sponsor.contactPersonEmail }}){% endif %}</td>
	</tr>
	{% endif %}
	{% if sponsor.phone %}
	<tr>
		<td>Phone</td>
		<td>{{ sponsor.phone }}</td>
	</tr>
	{% endif %}
	{% if sponsor.website %}
	<tr>
		<td>Website</td>
		<td>{{ sponsor.website }}</td>
	</tr>
	{% endif %}
</table>

<h2>Sponsorship Package</h2>
<table>
	<tr>
		<td>Package Tier</td>
		<td>{{ package.name }}</td>
	</tr>
	<tr>
		<td>Price</td>
		<td>${{ package.price|number_format(2) }}</td>
	</tr>
	<tr>
		<td>Tables</td>
		<td>{{ package.numberOfTables }} table(s), {{ package.seatsPerTable }} seats each</td>
	</tr>
	{% if package.benefits %}
	<tr>
		<td>Benefits</td>
		<td>{{ package.benefits }}</td>
	</tr>
	{% endif %}
	{% if package.description %}
	<tr>
		<td>Description</td>
		<td>{{ package.description }}</td>
	</tr>
	{% endif %}
</table>

<h2>Terms and Conditions</h2>
<div class="terms">
	<ol>
		<li>The Sponsor agrees to pay the sponsorship fee as outlined in the selected package within 30 days of signing this agreement.</li>
		<li>The event organizer will provide all benefits listed in the sponsorship package, including but not limited to branding, table allocation, and promotional materials placement.</li>
		<li>In the event of cancellation by the Sponsor, a written notice must be provided at least 14 days prior to the event date. A cancellation fee of 50% of the package price may apply.</li>
		<li>The event organizer reserves the right to modify event logistics while ensuring that sponsorship benefits are honored in substance.</li>
		<li>Both parties agree to act in good faith and maintain professional standards throughout the duration of this agreement.</li>
		<li>This agreement shall be governed by applicable local laws.</li>
	</ol>
</div>

<div class="signature-section">
	<h2>Signatures</h2>
	<table>
		<tr>
			<td style="width: 50%; font-weight: normal;">
				<strong>Event Organizer</strong>
				<div class="signature-line"></div>
				<p>Name: _________________________<br />Date: {{ date|date('F j, Y') }}</p>
			</td>
			<td style="width: 50%; font-weight: normal;">
				<strong>Sponsor Representative</strong>
				<div class="signature-line"></div>
				<p>Name: {{ sponsor.contactPersonName ?? sponsor.name }}<br />Date: _________________________</p>
			</td>
		</tr>
	</table>
</div>

<div class="footer">
	Generated by Eventify on {{ date|date('F j, Y \\a\\t H:i') }} &mdash; This document requires electronic signature to be legally binding.
</div>

</body>
</html>
