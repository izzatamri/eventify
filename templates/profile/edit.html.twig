{% extends 'layout_events.html.twig' %}

{% block title %}Edit profile - Eventify{% endblock %}
{% block page_heading %}Edit profile{% endblock %}
{% block page_breadcrumb %}<a href="{{ path('app_profile_show') }}">Profile</a> / Edit{% endblock %}

{% block content %}
<div class="container py-4">
	<div class="row justify-content-center">
		<div class="col-lg-6">
			<p class="mb-3"><a href="{{ path('app_profile_show') }}" class="text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Back to profile</a></p>
			<div class="card border-0 shadow-sm">
				<div class="card-body p-4">
					<h2 class="h5 fw-bold mb-4">Update your profile</h2>
					{{ form_start(form) }}
						<div class="mb-3">
							{{ form_label(form.email) }}
							{{ form_widget(form.email, { attr: { class: 'form-control' ~ (form.email.vars.errors|length ? ' is-invalid' : '') } }) }}
							{{ form_errors(form.email) }}
						</div>
						<div class="row g-3 mb-3">
							<div class="col-md-6">
								{{ form_label(form.firstName) }}
								{{ form_widget(form.firstName, { attr: { class: 'form-control' ~ (form.firstName.vars.errors|length ? ' is-invalid' : '') } }) }}
								{{ form_errors(form.firstName) }}
							</div>
							<div class="col-md-6">
								{{ form_label(form.lastName) }}
								{{ form_widget(form.lastName, { attr: { class: 'form-control' ~ (form.lastName.vars.errors|length ? ' is-invalid' : '') } }) }}
								{{ form_errors(form.lastName) }}
							</div>
						</div>
						<div class="mb-3">
							{{ form_label(form.plainPassword.first) }}
							<p class="small text-muted mb-1">Leave blank to keep your current password.</p>
							{{ form_widget(form.plainPassword.first, { attr: { class: 'form-control' ~ (form.plainPassword.first.vars.errors|length ? ' is-invalid' : '') } }) }}
							{{ form_errors(form.plainPassword.first) }}
						</div>
						<div class="mb-4">
							{{ form_label(form.plainPassword.second) }}
							{{ form_widget(form.plainPassword.second, { attr: { class: 'form-control' ~ (form.plainPassword.second.vars.errors|length ? ' is-invalid' : '') } }) }}
							{{ form_errors(form.plainPassword.second) }}
							{{ form_errors(form.plainPassword) }}
						</div>
						<div class="d-flex gap-2">
							<button type="submit" class="btn btn-primary">Save changes</button>
							<a href="{{ path('app_profile_show') }}" class="btn btn-outline-secondary">Cancel</a>
						</div>
					{{ form_end(form) }}
				</div>
			</div>
		</div>
	</div>
</div>
{% endblock %}
