<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<title>Ticket – {{ order.event.title }}</title>
	<style>
		body { 
			font-family: DejaVu Sans, sans-serif; 
			font-size: 13px; 
			color: #333; 
			padding: 0; 
			margin: 0;
			background: #f8f9fa;
		}
		.ticket-container {
			max-width: 800px;
			margin: 30px auto;
			background: white;
			border-radius: 15px;
			overflow: hidden;
			box-shadow: 0 4px 20px rgba(0,0,0,0.1);
		}
		.ticket-header { 
			background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
			color: white;
			padding: 30px;
			text-align: center;
		}
		.ticket-header h1 { 
			font-size: 28px; 
			margin: 0 0 8px 0; 
			font-weight: 700;
			color: white;
		}
		.ticket-header p {
			margin: 0;
			font-size: 14px;
			opacity: 0.9;
		}
		.ticket-body {
			padding: 30px;
		}
		.info-section {
			background: #f8f9fa;
			border-radius: 10px;
			padding: 20px;
			margin-bottom: 25px;
		}
		.info-section h2 {
			font-size: 16px;
			font-weight: 700;
			color: #0d6efd;
			margin: 0 0 15px 0;
			text-transform: uppercase;
			letter-spacing: 0.5px;
		}
		table { 
			width: 100%; 
			border-collapse: collapse;
		}
		tr {
			border-bottom: 1px solid #e9ecef;
		}
		tr:last-child {
			border-bottom: none;
		}
		td { 
			padding: 12px 0; 
			vertical-align: top;
		}
		td:first-child { 
			font-weight: 700; 
			color: #0d6efd; 
			width: 140px;
			font-size: 11px;
			text-transform: uppercase;
			letter-spacing: 0.8px;
			font-family: DejaVu Sans, Helvetica, Arial, sans-serif;
		}
		td:last-child {
			color: #333;
			font-size: 14px;
		}
		.qr-section { 
			text-align: center; 
			background: #f8f9fa;
			border-radius: 10px;
			padding: 25px;
			margin-bottom: 25px;
		}
		.qr-section h2 {
			font-size: 16px;
			font-weight: 700;
			color: #0d6efd;
			margin: 0 0 15px 0;
			text-transform: uppercase;
			letter-spacing: 0.5px;
		}
		.qr-section img { 
			max-width: 220px; 
			height: auto;
			border: 3px solid white;
			border-radius: 10px;
			background: white;
			padding: 15px;
			box-shadow: 0 2px 8px rgba(0,0,0,0.1);
		}
		.qr-section p {
			margin: 15px 0 0 0;
			color: #666;
			font-size: 12px;
		}
		.status-badge {
			display: inline-block;
			padding: 6px 14px;
			border-radius: 6px;
			font-weight: 600;
			font-size: 12px;
			text-transform: uppercase;
			letter-spacing: 0.3px;
		}
		.status-confirmed {
			background: #d1f4e0;
			color: #0f5132;
		}
		.status-cancelled {
			background: #f8d7da;
			color: #842029;
		}
		.status-pending {
			background: #fff3cd;
			color: #664d03;
		}
		.footer { 
			background: #f8f9fa;
			padding: 20px 30px;
			text-align: center;
			font-size: 11px; 
			color: #666;
			border-top: 1px solid #e9ecef;
		}
		.footer strong {
			color: #0d6efd;
			font-weight: 700;
		}
		.important-note {
			background: #e7f3ff;
			border-left: 4px solid #0d6efd;
			padding: 15px;
			border-radius: 8px;
			margin-bottom: 20px;
		}
		.important-note p {
			margin: 0;
			color: #333;
			font-size: 13px;
			line-height: 1.6;
		}
	</style>
</head>
<body>
	<div class="ticket-container">
		<div class="ticket-header">
			<h1>{{ order.event.title }}</h1>
			<p>Official Event Ticket</p>
		</div>

		<div class="ticket-body">
			<div class="important-note">
				<p><strong>Important:</strong> Present this ticket (PDF or QR code) at the event entrance for entry. Please arrive 15 minutes before the event start time.</p>
			</div>

			<div class="info-section">
				<h2>Event Information</h2>
				<table>
					<tr>
						<td>Event Name</td>
						<td><strong>{{ order.event.title }}</strong></td>
					</tr>
					<tr>
						<td>Date & Time</td>
						<td>{{ order.event.startDatetime ? order.event.startDatetime|date('l, F j, Y \\a\\t g:i A') : 'To Be Announced' }}</td>
					</tr>
					<tr>
						<td>Location</td>
						<td>{{ order.event.venue ? order.event.venue.name : 'Online / TBA' }}{% if order.event.venue and order.event.venue.address %}<br>{{ order.event.venue.address }}{% endif %}</td>
					</tr>
				</table>
			</div>

			<div class="info-section">
				<h2>Ticket Details</h2>
				<table>
					<tr>
						<td>Ticket Type</td>
						<td><strong>{{ order.ticket.name }}</strong></td>
					</tr>
					<tr>
						<td>Quantity</td>
						<td><strong>{{ order.quantity }}x</strong></td>
					</tr>
					<tr>
						<td>Order Number</td>
						<td>#{{ order.id }}</td>
					</tr>
					<tr>
						<td>Status</td>
						<td>
							<span class="status-badge status-{{ order.status }}">{{ order.status|capitalize }}</span>
						</td>
					</tr>
					<tr>
						<td>Purchase Date</td>
						<td>{{ order.createdAt|date('F j, Y \\a\\t g:i A') }}</td>
					</tr>
				</table>
			</div>

			{% if qrCodeDataUri %}
			<div class="qr-section">
				<h2>Entry QR Code</h2>
				<img src="{{ qrCodeDataUri }}" alt="Ticket QR code" />
				<p>Scan this code at the event entrance for quick check-in</p>
			</div>
			{% endif %}
		</div>

		<div class="footer">
			<strong>Eventify</strong> | Order placed on {{ order.createdAt|date('F j, Y') }}<br>
			For support, please contact support@eventify.com
		</div>
	</div>
</body>
</html>
