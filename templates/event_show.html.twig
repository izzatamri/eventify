<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{{ event.title }} - Eventify</title>
		<link rel="shortcut icon" href="/assets/img/logo/fav-logo1.png" />
		<link rel="stylesheet" href="/assets/css/vendor/bootstrap.min.css" />
		<link rel="stylesheet" href="/assets/css/vendor/aos.css" />
		<link rel="stylesheet" href="/assets/css/vendor/fontawesome.css" />
		<link rel="stylesheet" href="/assets/css/vendor/magnific-popup.css" />
		<link rel="stylesheet" href="/assets/css/vendor/mobile.css" />
		<link rel="stylesheet" href="/assets/css/vendor/owlcarousel.min.css" />
		<link rel="stylesheet" href="/assets/css/vendor/sidebar.css" />
		<link rel="stylesheet" href="/assets/css/vendor/slick-slider.css" />
		<link rel="stylesheet" href="/assets/css/vendor/nice-select.css" />
		<link rel="stylesheet" href="/assets/css/vendor/odometer.css" />
		<link rel="stylesheet" href="/assets/css/main.css" />
		<script src="/assets/js/vendor/jquery-3.7.1.min.js"></script>
	</head>
	<body class="homepage1-body">
		<div id="popup" class="popup-overlay d-none"></div>
		<div class="preloader">
			<div class="loading-container">
				<div class="loading"></div>
				<div id="loading-icon"><img src="/assets/img/logo/preloader.png" alt="" /></div>
			</div>
		</div>
		<div class="paginacontainer">
			<div class="progress-wrap">
				<svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
					<path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
				</svg>
			</div>
		</div>

		<header>
			<div class="header-area homepage1 header header-sticky d-none d-lg-block" id="header">
				<div class="container">
					<div class="row">
						<div class="col-lg-12">
							<div class="header-elements">
								<div class="site-logo">
									<a href="{{ path('app_home') }}"><img src="/assets/img/logo/logo1.png" alt="" /></a>
								</div>
								<div class="main-menu">
									<ul>
										<li><a href="{{ path('app_home') }}">Home</a></li>
										<li>
											<a href="#">Events <i class="fa-solid fa-angle-down"></i></a>
											<ul class="dropdown-padding">
												<li><a href="{{ path('app_events') }}">Events</a></li>
												<li><a href="{{ path('app_event_create') }}">Create Events</a></li>
											</ul>
										</li>
										<li><a href="about.html">About Event</a></li>
										<li><a href="contact.html">Contact Us</a></li>
									</ul>
								</div>
								<div class="btn-area">
									<ul>
										<li><a href="#"><i class="fa-brands fa-facebook-f"></i></a></li>
										<li><a href="#"><i class="fa-brands fa-instagram"></i></a></li>
										<li><a href="#"><i class="fa-brands fa-linkedin-in"></i></a></li>
									</ul>
								</div>
								<div class="body-overlay"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</header>

		<div class="mobile-header mobile-haeder1 d-block d-lg-none">
			<div class="container-fluid">
				<div class="col-12">
					<div class="mobile-header-elements">
						<div class="mobile-logo">
							<a href="{{ path('app_home') }}"><img src="/assets/img/logo/logo1.png" alt="" /></a>
						</div>
						<div class="mobile-nav-icon dots-menu"><i class="fa-solid fa-bars-staggered"></i></div>
					</div>
				</div>
			</div>
		</div>
		<div class="mobile-sidebar mobile-sidebar1">
			<div class="logosicon-area">
				<div class="logos"><img src="/assets/img/logo/logo2.png" alt="" /></div>
				<div class="menu-close"><i class="fa-solid fa-xmark"></i></div>
			</div>
			<div class="mobile-nav mobile-nav1">
				<ul class="mobile-nav-list nav-list1">
					<li><a href="{{ path('app_home') }}">Home</a></li>
					<li><a href="{{ path('app_events') }}">Events</a></li>
					<li><a href="contact.html">Contact Us</a></li>
				</ul>
			</div>
		</div>

		{# ----- EVENT HERO BANNER ----- #}
		<div class="inner-page-header position-relative" style="min-height: 380px; background-image: url({{ event.image ?: '/assets/img/bg/header-bg6.png' }}); background-size: cover; background-position: center;">
			<div class="position-absolute w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%); top: 0; left: 0;"></div>
			<div class="container position-relative" style="z-index: 2;">
				<div class="row align-items-end" style="min-height: 380px; padding-bottom: 2rem;">
					<div class="col-lg-12">
						<h1 class="text-white mb-2" style="font-size: 2.5rem; font-weight: 700;">{{ event.title }}</h1>
						<p class="text-white mb-1">
							{% if event.startDatetime %}
								{{ event.startDatetime|date('d M Y') }}
							{% endif %}
							{% if event.venue %}
								<span class="ms-3"><i class="fa-solid fa-location-dot me-1"></i>{{ event.venue.name }}</span>
							{% endif %}
						</p>
						<a href="{{ path('app_home') }}" class="text-white small">Home <i class="fa-solid fa-angle-right"></i> <span>{{ event.title }}</span></a>
					</div>
				</div>
			</div>
		</div>

		{# ----- EVENT DETAIL CONTENT ----- #}
		<div class="container py-5">
			<div class="row">
				<div class="col-lg-8">
					<h2 class="h3 fw-bold mb-3">{{ event.title }}</h2>
					{% if event.organizer %}
						<p class="text-muted mb-2">
							By {{ event.organizer.name }}
							<button type="button" class="btn btn-sm btn-outline-secondary border ms-2">Follow</button>
						</p>
					{% endif %}
					{% if event.venue %}
						<p class="text-muted mb-1"><i class="fa-solid fa-location-dot me-2"></i>{{ event.venue.name }}{% if event.venue.city %} • {{ event.venue.city }}{% if event.venue.country %}, {{ event.venue.country }}{% endif %}{% endif %}</p>
					{% endif %}
					<p class="text-muted mb-4">
						<i class="fa-solid fa-calendar me-2"></i>
						{% if event.startDatetime and event.endDatetime %}
							{{ event.startDatetime|date('l, M d') }} from {{ event.startDatetime|date('g a') }} to {{ event.endDatetime|date('g a') }}
						{% elseif event.startDatetime %}
							{{ event.startDatetime|date('l d F Y, H:i') }}
						{% endif %}
					</p>

					<h3 class="h5 fw-bold mt-4 mb-2">Overview</h3>
					<div class="mb-4">{{ event.description|nl2br }}</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Good to know</h3>
					<div class="border rounded p-3 mb-4 shadow-sm">
						<p class="mb-1 text-muted"><i class="fa-regular fa-clock me-2"></i>{% if event.startDatetime and event.endDatetime %}{% set diff = event.endDatetime.diff(event.startDatetime) %}{{ diff.days * 24 + diff.h }} hours{% else %}—{% endif %}</p>
						<p class="mb-0 text-muted"><i class="fa-solid fa-location-dot me-2"></i>{% if event.venue %}In person{% else %}Online / TBA{% endif %}</p>
					</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Location</h3>
					{% if event.venue %}
						<p class="fw-bold mb-1">{{ event.venue.name }}</p>
						<p class="text-muted mb-3">{% if event.venue.address %}{{ event.venue.address }}{% endif %}{% if event.venue.city %} {{ event.venue.city }}{% endif %}{% if event.venue.state %} {{ event.venue.state }}{% endif %}{% if event.venue.postalCode %} {{ event.venue.postalCode }}{% endif %}</p>
						<div class="border rounded bg-light mb-4 d-flex align-items-center justify-content-center" style="height: 200px;">
							<button type="button" class="btn btn-outline-secondary">Show map</button>
						</div>
					{% else %}
						<p class="text-muted mb-4">Location to be announced.</p>
					{% endif %}

					<h3 class="h5 fw-bold mt-4 mb-2">How do you want to get there?</h3>
					<div class="d-flex flex-wrap gap-2 mb-4">
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-car me-1"></i>Driving</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-bus me-1"></i>Public transport</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-bicycle me-1"></i>Biking</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-person-walking me-1"></i>Walking</button>
					</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Organized by</h3>
					{% if event.organizer %}
						<div class="border rounded p-3 mb-3 shadow-sm d-flex align-items-center flex-wrap">
							<div class="rounded-circle bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center me-3" style="width: 56px; height: 56px;">
								<span class="fw-bold text-secondary">{{ event.organizer.name|slice(0, 2)|upper }}</span>
							</div>
							<div class="flex-grow-1">
								<p class="fw-bold mb-1">{{ event.organizer.name }}</p>
								<p class="small text-muted mb-0">Events · Organizer</p>
							</div>
							<div>
								<button type="button" class="btn btn-outline-secondary btn-sm me-1">Contact</button>
								<button type="button" class="btn btn-sm vl-btn4">Follow</button>
							</div>
						</div>
					{% endif %}
					<p class="small"><a href="#" class="text-primary"><i class="fa-regular fa-flag me-1"></i>Report this event</a></p>

					{% if otherEvents|length > 0 %}
						<h3 class="h5 fw-bold mt-5 mb-3">Other events you may like</h3>
						<ul class="list-unstyled">
							{% for other in otherEvents %}
								<li class="border-bottom py-3 d-flex align-items-center">
									<div class="flex-grow-1">
										<a href="{{ path('app_event_show', { id: other.id }) }}" class="fw-bold text-dark text-decoration-none">{{ other.title }}</a>
										<p class="small text-muted mb-0">
											{% if other.startDatetime %}{{ other.startDatetime|date('D, d M') }} · {{ other.startDatetime|date('H:i') }}{% endif %}
											{% if other.venue %} · {{ other.venue.name }}{% endif %}
										</p>
										<p class="small text-muted mb-0">{{ other.priceLabel }}</p>
									</div>
									<a href="{{ path('app_event_show', { id: other.id }) }}" class="btn btn-sm vl-btn4">Reserve a spot</a>
								</li>
							{% endfor %}
						</ul>
					{% endif %}
				</div>

				<div class="col-lg-4">
					<div class="position-sticky" style="top: 100px;">
						<div class="border rounded p-4 shadow-sm bg-white">
							<div class="d-flex justify-content-end gap-2 mb-3">
								<button type="button" class="btn btn-link btn-sm text-dark p-0"><i class="fa-solid fa-arrow-up-from-bracket"></i></button>
								<button type="button" class="btn btn-link btn-sm text-dark p-0"><i class="fa-regular fa-heart"></i></button>
							</div>
							<p class="h5 fw-bold mb-1">{{ event.priceLabel }}</p>
							<p class="text-muted small mb-3">{% if event.startDatetime %}{{ event.startDatetime|date('M d') }} · {{ event.startDatetime|date('g:i a') }}{% endif %}</p>
							<a href="{{ path('app_events') }}" class="btn vl-btn4 w-100 mb-2">Reserve a spot</a>
							<div class="pt-3 border-top mt-3">
								<a href="{{ path('app_event_edit', { id: event.id }) }}" class="btn btn-outline-secondary btn-sm me-1">Edit</a>
								<form method="post" action="{{ path('app_event_delete', { id: event.id }) }}" class="d-inline" onsubmit="return confirm('Delete this event?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}" />
									<button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
								</form>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ----- FOOTER (same as events.html.twig) ----- #}
		<div class="footer1-sertion-area">
			<div class="container">
				<div class="row">
					<div class="col-lg-3 col-md-6">
						<div class="footer-logo-area">
							<img src="/assets/img/logo/logo2.png" alt="" />
							<div class="space16"></div>
							<p>We are committed to creating a platform where business leaders, innovators, and professionals can come together to exchange ideas</p>
							<div class="space24"></div>
							<ul>
								<li><a href="#"><i class="fa-brands fa-facebook-f"></i></a></li>
								<li><a href="#"><i class="fa-brands fa-instagram"></i></a></li>
								<li><a href="#"><i class="fa-brands fa-linkedin-in"></i></a></li>
								<li><a href="#" class="m-0"><i class="fa-brands fa-pinterest-p"></i></a></li>
							</ul>
						</div>
					</div>
					<div class="col-lg-2 col-md-6">
						<div class="link-content">
							<h3>Quick Links</h3>
							<ul>
								<li><a href="about.html">About Us</a></li>
								<li><a href="blog.html">Our Blogs</a></li>
								<li><a href="{{ path('app_events') }}">Event Listing</a></li>
								<li><a href="pricing-plan.html">Pricing Plan</a></li>
								<li><a href="contact.html">Contact Us</a></li>
							</ul>
						</div>
					</div>
					<div class="col-lg-3 col-md-6">
						<div class="link-content2">
							<h3>Contact Us</h3>
							<ul>
								<li><a href="tel:+11234567890"><img src="/assets/img/icons/phn1.svg" alt="" />+1 123 456 7890</a></li>
								<li><a href="#"><img src="/assets/img/icons/location1.svg" alt="" />Secret Location In The UK</a></li>
								<li><a href="mailto:eventifyevent@gmail.com"><img src="/assets/img/icons/mail1.svg" alt="" />eventifyevent@gmail.com</a></li>
								<li><a href="#"><img src="/assets/img/icons/world1.svg" alt="" />eventifyevent.com</a></li>
							</ul>
						</div>
					</div>
					<div class="col-lg-4 col-md-6">
						<div class="footer-social-box">
							<h3>Our Recent Event Gallery</h3>
							<div class="space12"></div>
							<div class="row">
								{% for i in 1..6 %}
								<div class="col-lg-4 col-md-4 col-4">
									<div class="img1">
										<img src="/assets/img/all-images/footer/footer-img{{ i }}.png" alt="" />
										<div class="icons"><a href="#"><i class="fa-brands fa-instagram"></i></a></div>
									</div>
								</div>
								{% endfor %}
							</div>
						</div>
					</div>
				</div>
				<div class="space60"></div>
				<div class="row">
					<div class="col-lg-12">
						<div class="copyright">
							<p>&copy; Copyright 2024 - Eventify. All Right Reserved</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<script src="/assets/js/vendor/bootstrap.min.js"></script>
		<script src="/assets/js/vendor/fontawesome.js"></script>
		<script src="/assets/js/vendor/aos.js"></script>
		<script src="/assets/js/vendor/sidebar.js"></script>
		<script src="/assets/js/vendor/mobilemenu.js"></script>
		<script src="/assets/js/main.js"></script>
		<script>
			function hidePreloader() {
				$('.preloader').fadeOut(300);
			}
			$(window).on('load', function() {
				setTimeout(hidePreloader, 200);
			});
			setTimeout(hidePreloader, 2500);
		</script>
	</body>
</html>
