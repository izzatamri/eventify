					<div class="mobile-header-elements">
						<div class="mobile-logo">
							<a href="{{ path('app_home') }}"><img src="/assets/img/logo/logo1.png" alt="" /></a>
						</div>
						<div class="mobile-nav-icon dots-menu"><i class="fa-solid fa-bars-staggered"></i></div>
					</div>
				</div>
			</div>
		</div>
		<div class="mobile-sidebar mobile-sidebar1">
			<div class="logosicon-area">
				<div class="logos"><img src="/assets/img/logo/logo2.png" alt="" /></div>
				<div class="menu-close"><i class="fa-solid fa-xmark"></i></div>
			</div>
			<div class="mobile-nav mobile-nav1">
				<ul class="mobile-nav-list nav-list1">
					<li><a href="{{ path('app_home') }}">Home</a></li>
					<li><a href="{{ path('app_events') }}">Events</a></li>
					<li><a href="contact.html">Contact Us</a></li>
				</ul>
			</div>
		</div>

		{# ----- EVENT HERO BANNER ----- #}
		<div class="inner-page-header" style="background-image: url(/assets/img/bg/header-bg6.png); padding: 100px 0;">
			<div class="container">
				<div class="row">
					<div class="col-lg-8 m-auto">
						<div class="heading1 text-center">
							<h1 style="font-size: 48px; margin-bottom: 20px;">{{ event.title }}</h1>
							{% if event.description %}
								<p style="font-size: 18px; color: rgba(255,255,255,0.9); margin-bottom: 30px;">
									{{ event.description|length > 120 ? event.description|slice(0, 120) ~ '...' : event.description }}
								</p>
							{% endif %}
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ----- EVENT DETAIL CONTENT ----- #}
		<div class="container py-5">
			<div class="row g-4">
				<div class="col-lg-8">
					{# Organizer Card #}
					{% if event.organizer %}
					<div class="card border-0 mb-4" style="border-radius: 15px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
						<div class="card-body p-4">
							<div class="d-flex align-items-center">
								<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 56px; height: 56px; flex-shrink: 0;">
									<span class="fw-bold text-primary" style="font-size: 18px;">{{ event.organizer.name|slice(0, 2)|upper }}</span>
								</div>
								<div class="flex-grow-1">
									<p class="text-muted mb-0" style="font-size: 13px;">Organized by</p>
									<p class="fw-bold mb-0" style="font-size: 16px; color: #333;">{{ event.organizer.name }}</p>
								</div>
								<button type="button" class="btn btn-outline-primary btn-sm" style="border-radius: 8px;">Follow</button>
							</div>
						</div>
					</div>
					{% endif %}

					{# About Event Card #}
					<div class="card border-0 mb-4" style="border-radius: 15px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
						<div class="card-body p-4">
							<h3 class="fw-bold mb-3" style="font-size: 20px; color: #333;">About This Event</h3>
							<div style="color: #555; line-height: 1.7;">{{ event.description|nl2br }}</div>
						</div>
					</div>

					{# Event Details Card #}
					<div class="card border-0 mb-4" style="border-radius: 15px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
						<div class="card-body p-4">
							<h3 class="fw-bold mb-4" style="font-size: 20px; color: #333;">Event Details</h3>
							<div class="row g-3">
								<div class="col-md-6">
									<div class="d-flex align-items-start">
										<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
											<i class="fa-solid fa-calendar-days text-primary"></i>
										</div>
										<div>
											<p class="text-muted mb-1" style="font-size: 13px;">Date & Time</p>
											<p class="fw-semibold mb-0" style="font-size: 15px; color: #333;">
												{% if event.startDatetime and event.endDatetime %}
													{{ event.startDatetime|date('l, M d') }}<br>
													{{ event.startDatetime|date('g:i A') }} - {{ event.endDatetime|date('g:i A') }}
												{% elseif event.startDatetime %}
													{{ event.startDatetime|date('l, F j, Y') }}<br>
													{{ event.startDatetime|date('g:i A') }}
												{% endif %}
											</p>
										</div>
									</div>
								</div>
								<div class="col-md-6">
									<div class="d-flex align-items-start">
										<div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
											<i class="fa-solid fa-clock text-success"></i>
										</div>
										<div>
											<p class="text-muted mb-1" style="font-size: 13px;">Duration</p>
											<p class="fw-semibold mb-0" style="font-size: 15px; color: #333;">
												{% if event.startDatetime and event.endDatetime %}
													{% set diff = event.endDatetime.diff(event.startDatetime) %}
													{{ diff.days * 24 + diff.h }} hours
												{% else %}
													TBA
												{% endif %}
											</p>
										</div>
									</div>
								</div>
								<div class="col-md-6">
									<div class="d-flex align-items-start">
										<div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
											<i class="fa-solid fa-location-dot text-danger"></i>
										</div>
										<div>
											<p class="text-muted mb-1" style="font-size: 13px;">Venue Type</p>
											<p class="fw-semibold mb-0" style="font-size: 15px; color: #333;">{% if event.venue %}In-Person Event{% else %}Online / TBA{% endif %}</p>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>

					{# Location Card #}
					{% if event.venue %}
					<div class="card border-0 mb-4" style="border-radius: 15px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
						<div class="card-body p-4">
							<h3 class="fw-bold mb-3" style="font-size: 20px; color: #333;">Location</h3>
							<div class="d-flex align-items-start mb-3">
								<div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
									<i class="fa-solid fa-map-marker-alt text-danger"></i>
								</div>
								<div>
									<p class="fw-bold mb-1" style="font-size: 16px; color: #333;">{{ event.venue.name }}</p>
									<p class="text-muted mb-0" style="font-size: 14px;">
										{% if event.venue.address %}{{ event.venue.address }}{% endif %}
										{% if event.venue.city %}<br>{{ event.venue.city }}{% endif %}
										{% if event.venue.state %}, {{ event.venue.state }}{% endif %}
										{% if event.venue.postalCode %} {{ event.venue.postalCode }}{% endif %}
									</p>
								</div>
							</div>
							<div class="rounded bg-light d-flex align-items-center justify-content-center" style="height: 200px; border: 2px dashed #dee2e6;">
								<button type="button" class="btn btn-primary" style="border-radius: 8px;"><i class="fa-solid fa-map me-2"></i>View on Map</button>
							</div>
						</div>
					</div>
					{% endif %}

					{# Sponsors Card #}
					{% set visible_sponsors = event.sponsors|filter(s => s.status == 'active') %}
					{% if visible_sponsors|length > 0 %}
					<div class="card border-0 mb-4" style="border-radius: 15px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
						<div class="card-body p-4">
							<h3 class="fw-bold mb-3" style="font-size: 20px; color: #333;">Event Sponsors</h3>
							<div class="d-flex flex-wrap gap-3">
								{% for sponsor in visible_sponsors %}
									<div class="d-flex align-items-center gap-3 border rounded p-3" style="border-radius: 10px;">
										{% if sponsor.logoUrl %}
											<img src="{{ sponsor.logoUrl }}" alt="{{ sponsor.name }}" class="rounded" style="width: 56px; height: 56px; object-fit: contain; background: #fff;" />
										{% else %}
											<div class="rounded d-flex align-items-center justify-content-center bg-secondary bg-opacity-25 text-secondary fw-bold" style="width: 56px; height: 56px; font-size: 1rem;">{{ sponsor.name|slice(0, 2)|upper }}</div>
										{% endif %}
										<div>
											<span class="fw-semibold">{{ sponsor.name }}</span>
											{% if sponsor.website %}
												<a href="{{ sponsor.website }}" target="_blank" rel="noopener" class="small text-muted ms-1"><i class="fa-solid fa-external-link-alt"></i></a>
											{% endif %}
										</div>
									</div>
								{% endfor %}
							</div>
						</div>
					</div>
					{% endif %}

					{% if event.sponsorshipPackages|length > 0 %}
						<h3 class="h5 fw-bold mt-4 mb-2">Sponsorship packages</h3>
						<p class="text-muted small mb-3">Support this event by choosing a sponsorship package.</p>
						<div class="row g-3 mb-4">
							{% for package in event.sponsorshipPackages %}
								<div class="col-md-6 col-lg-4">
									<div class="border rounded p-3 h-100 shadow-sm d-flex flex-column">
										<div class="fw-bold text-primary mb-1">{{ package.name }}</div>
										<div class="h5 mb-2">${{ package.price|number_format(2) }}</div>
										{% if package.description %}
											<p class="small text-muted mb-2">{{ package.description }}</p>
										{% endif %}
										<p class="small mb-1"><i class="fa-solid fa-table-cells me-1"></i>{{ package.numberOfTables }} table(s) · {{ package.seatsPerTable }} seats/table</p>
										{% if package.benefits %}
											<p class="small text-muted mb-2">{{ package.benefits|nl2br }}</p>
										{% endif %}
										<button type="button" class="btn btn-primary btn-sm mt-auto sponsor-request-btn" data-submit-url="{{ path('app_sponsor_request_submit', { id: event.id, packageId: package.id }) }}" data-package-name="{{ package.name }}"><i class="fa-solid fa-handshake me-1"></i>Become a sponsor</button>
									</div>
								</div>
							{% endfor %}
						</div>
					{% endif %}

				</div>

				<div class="col-lg-4">
					<div class="position-sticky" style="top: 100px;">
						<div class="card border-0" style="border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
							<div class="card-body p-4">
								{# Event Image #}
								{% if event.image %}
								<div class="rounded mb-4" style="overflow: hidden; height: 200px;">
									<img src="{{ event.image }}" alt="{{ event.title }}" style="width: 100%; height: 100%; object-fit: cover;">
								</div>
								{% endif %}
								
								{# Pricing #}
								<div class="mb-4">
									<p class="text-muted mb-1" style="font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Ticket Price</p>
									<p class="h3 fw-bold mb-0" style="color: #198754;">{{ event.priceLabel }}</p>
								</div>
								
								{# CTA Button #}
								<button type="button" class="btn btn-primary w-100 btn-lg mb-3" id="open-ticket-checkout" style="border-radius: 10px; font-weight: 600;">
									<i class="fa-solid fa-ticket me-2"></i>Get Tickets
								</button>
								
								{# Quick Actions #}
								<div class="d-flex gap-2 mb-4">
									<button type="button" class="btn btn-outline-secondary flex-fill" id="share-event-btn" style="border-radius: 8px;" title="Share this event">
										<i class="fa-solid fa-share-nodes"></i>
									</button>
									<button type="button" class="btn btn-outline-secondary flex-fill" id="favorite-event-btn" style="border-radius: 8px;" title="Save to favorites">
										<i class="fa-regular fa-heart"></i>
									</button>
								</div>
							{% if is_granted('EVENT_EDIT', event) %}
							<div class="pt-3 border-top mt-3">
								<a href="{{ path('app_orders_event', { id: event.id }) }}" class="btn btn-outline-primary btn-sm me-1">View orders</a>
								<a href="{{ path('app_sponsorship_package_index', { id: event.id }) }}" class="btn btn-outline-primary btn-sm me-1">Packages</a>
								<a href="{{ path('app_sponsor_index', { id: event.id }) }}" class="btn btn-outline-primary btn-sm me-1">Sponsors</a>
								<a href="{{ path('app_service_booking_index', { eventId: event.id }) }}" class="btn btn-outline-primary btn-sm me-1"><i class="fa-solid fa-truck me-1"></i>Service bookings</a>
								<a href="{{ path('app_event_edit', { id: event.id }) }}" class="btn btn-outline-secondary btn-sm me-1">Edit</a>
								<form method="post" action="{{ path('app_event_delete', { id: event.id }) }}" class="d-inline" onsubmit="return confirm('Delete this event?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}" />
									<button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
								</form>
							</div>
							{% endif %}
						</div>
					</div>
					
					{# Other Events Card #}
					{% if otherEvents|length > 0 %}
					<div class="card border-0 mt-4" style="border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
						<div class="card-body p-4">
							<h3 class="fw-bold mb-3" style="font-size: 18px; color: #333;">Other Events You May Like</h3>
							<div class="list-group list-group-flush">
								{% for other in otherEvents|slice(0, 3) %}
									<div class="list-group-item border-0 px-0 py-3 {% if not loop.last %}border-bottom{% endif %}">
										<a href="{{ path('app_event_show', { id: other.id }) }}" class="fw-semibold text-dark text-decoration-none d-block mb-1" style="font-size: 15px;">{{ other.title }}</a>
										<p class="small text-muted mb-2">
											{% if other.startDatetime %}{{ other.startDatetime|date('D, d M') }} · {{ other.startDatetime|date('H:i') }}{% endif %}
											{% if other.venue %} · {{ other.venue.name }}{% endif %}
										</p>
										<div class="d-flex align-items-center justify-content-between">
											<span class="small fw-semibold text-success">{{ other.priceLabel }}</span>
											<a href="{{ path('app_event_show', { id: other.id }) }}" class="btn btn-sm btn-outline-primary" style="border-radius: 6px;">View</a>
										</div>
									</div>
								{% endfor %}
							</div>
						</div>
					</div>
					{% endif %}
				</div>
			</div>
		</div>

		{# ----- SPONSOR REQUEST MODAL ----- #}
		{% if event.sponsorshipPackages|length > 0 and sponsorRequestForm is defined %}
		<div class="sponsor-request-overlay" id="sponsor-request-modal" style="display: none; position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
			<div class="sponsor-request-dialog rounded shadow bg-white mx-3" style="max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto;">
				<div class="p-4 border-bottom d-flex justify-content-between align-items-center">
					<h3 class="h5 mb-0">Become a sponsor — <span id="sponsor-modal-package-name"></span></h3>
					<button type="button" class="btn btn-link text-dark p-0" id="sponsor-request-close" aria-label="Close">&times;</button>
				</div>
				<div class="p-4">
					{{ form_start(sponsorRequestForm, { attr: { id: 'sponsor-request-form', novalidate: 'novalidate' } }) }}
					{{ form_widget(sponsorRequestForm._token) }}
					<div class="mb-3">
						{{ form_label(sponsorRequestForm.name) }}
						{{ form_widget(sponsorRequestForm.name, { attr: { class: 'form-control' } }) }}
						{{ form_errors(sponsorRequestForm.name) }}
					</div>
					<div class="mb-3">
						{{ form_label(sponsorRequestForm.email) }}
						{{ form_widget(sponsorRequestForm.email, { attr: { class: 'form-control' } }) }}
						{{ form_errors(sponsorRequestForm.email) }}
					</div>
					<div class="row g-2">
						<div class="col-6 mb-3">
							{{ form_label(sponsorRequestForm.phone) }}
							{{ form_widget(sponsorRequestForm.phone, { attr: { class: 'form-control' } }) }}
							{{ form_errors(sponsorRequestForm.phone) }}
						</div>
						<div class="col-6 mb-3">
							{{ form_label(sponsorRequestForm.website) }}
							{{ form_widget(sponsorRequestForm.website, { attr: { class: 'form-control' } }) }}
							{{ form_errors(sponsorRequestForm.website) }}
						</div>
					</div>
					<div class="mb-3">
						{{ form_label(sponsorRequestForm.logoFile) }}
						{{ form_widget(sponsorRequestForm.logoFile, { attr: { class: 'form-control' } }) }}
						<p class="small text-muted mb-0">PNG, JPEG, JPG, WebP or GIF. Max 2 MB.</p>
						{{ form_errors(sponsorRequestForm.logoFile) }}
					</div>
					<div class="mb-3">
						{{ form_label(sponsorRequestForm.logoUrl) }}
						{{ form_widget(sponsorRequestForm.logoUrl, { attr: { class: 'form-control' } }) }}
						{{ form_errors(sponsorRequestForm.logoUrl) }}
					</div>
					<div class="mb-3">
						{{ form_label(sponsorRequestForm.description) }}
						{{ form_widget(sponsorRequestForm.description, { attr: { class: 'form-control', rows: 2 } }) }}
						{{ form_errors(sponsorRequestForm.description) }}
					</div>
					<div class="row g-2">
						<div class="col-6 mb-3">
							{{ form_label(sponsorRequestForm.contactPersonName) }}
							{{ form_widget(sponsorRequestForm.contactPersonName, { attr: { class: 'form-control' } }) }}
							{{ form_errors(sponsorRequestForm.contactPersonName) }}
						</div>
						<div class="col-6 mb-3">
							{{ form_label(sponsorRequestForm.contactPersonEmail) }}
							{{ form_widget(sponsorRequestForm.contactPersonEmail, { attr: { class: 'form-control' } }) }}
							{{ form_errors(sponsorRequestForm.contactPersonEmail) }}
						</div>
					</div>
					<div class="d-flex gap-2 mt-3">
						<button type="submit" class="btn btn-primary">Submit request</button>
						<button type="button" class="btn btn-outline-secondary" id="sponsor-request-cancel">Cancel</button>
					</div>
					{{ form_end(sponsorRequestForm) }}
				</div>
			</div>
		</div>
		{% endif %}

		{# ----- TICKET CHECKOUT MODAL ----- #}
		<div class="ticket-checkout-overlay" id="ticket-checkout"
			data-checkout-url="{{ path('app_stripe_create_checkout_session') }}"
			data-event-id="{{ event.id }}"
			data-checkout-token="{{ csrf_token('order_checkout_' ~ event.id) }}">
			<div class="ticket-checkout-backdrop"></div>
			<div class="ticket-checkout-modal" role="dialog" aria-modal="true" aria-labelledby="ticket-checkout-title">
				<button type="button" class="ticket-checkout-close" id="ticket-checkout-close" aria-label="Close checkout">&times;</button>
				<div class="ticket-checkout-main">
					{# Step 1: select tickets #}
					<div class="ticket-step ticket-step-1" id="ticket-step-1">
						<div class="ticket-checkout-header mb-3">
							<div class="ticket-checkout-header-title" id="ticket-checkout-title">{{ event.title }}</div>
							<div class="ticket-checkout-header-subtitle">
								{% if event.startDatetime %}{{ event.startDatetime|date('l, F j \\· g a') }}{% endif %}
							</div>
						</div>
						<div class="ticket-checkout-card">
							{% if event.tickets|length > 0 %}
								{% for ticket in event.tickets %}
									<div class="ticket-checkout-row" data-ticket-id="{{ ticket.id }}" data-ticket-name="{{ ticket.name }}" data-ticket-price="{{ ticket.price }}">
										<div class="me-3">
											<div class="ticket-name">{{ ticket.name }}</div>
											<div class="ticket-price">
												{% if ticket.price == '0' or ticket.price == '0.00' %}
													Free
												{% else %}
													${{ ticket.price }}
												{% endif %}
											</div>
											<div class="ticket-meta">
												{% if ticket.saleEnd %}Sales end {{ ticket.saleEnd|date('M j, Y') }}{% endif %}
											</div>
										</div>
										<div class="ticket-qty-control" aria-label="Quantity for {{ ticket.name }}">
											<button type="button" class="ticket-qty-btn ticket-qty-minus" aria-label="Decrease quantity">-</button>
											<span class="ticket-qty-value">0</span>
											<button type="button" class="ticket-qty-btn ticket-qty-plus" aria-label="Increase quantity">+</button>
										</div>
									</div>
								{% endfor %}
							{% else %}
								<p class="mb-0 small text-muted">No tickets are available for this event yet.</p>
							{% endif %}
						</div>
						<div class="ticket-checkout-footer">
							<button type="button" class="btn btn-primary btn-lg" id="ticket-checkout-continue" style="border-radius: 10px; padding: 12px 32px; font-weight: 600;">Continue to Checkout</button>
						</div>
					</div>

					{# Step 2: contact information #}
					<div class="ticket-step ticket-step-2 d-none" id="ticket-step-2">
						<div class="mb-4">
							<button type="button" class="btn btn-outline-secondary btn-sm mb-3" id="ticket-step2-back" style="border-radius: 8px;"><i class="fa-solid fa-arrow-left me-2"></i>Back</button>
							<h2 class="fw-bold mb-2" style="font-size: 1.5rem; color: #1f2937;">Complete Your Order</h2>
							<p class="text-muted mb-0" style="font-size: 0.95rem;">Enter your contact information to receive your tickets</p>
						</div>
						{% if is_granted('IS_AUTHENTICATED_FULLY') and app.user %}
							<p class="small text-muted mb-2">Logged in as <strong>{{ app.user.email }}</strong>. Not you? <a href="{{ path('app_logout') }}">Log out</a></p>
						{% endif %}
						<form id="ticket-contact-form">
							<div class="row mb-3">
								<div class="col-md-6">
									<label class="form-label small">First name *</label>
									<input type="text" class="form-control form-control-sm" name="firstName" value="{{ app.user.firstName ?? '' }}" required />
								</div>
								<div class="col-md-6">
									<label class="form-label small">Last name *</label>
									<input type="text" class="form-control form-control-sm" name="lastName" value="{{ app.user.lastName ?? '' }}" required />
								</div>
							</div>
							<div class="mb-3">
								<label class="form-label small">Email address *</label>
