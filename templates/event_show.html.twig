<<<<<<< HEAD
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{{ event.title }} - Eventify</title>
		<link rel="shortcut icon" href="/assets/img/logo/fav-logo1.png" />
		<link rel="stylesheet" href="/assets/css/vendor/bootstrap.min.css" />
		<link rel="stylesheet" href="/assets/css/vendor/aos.css" />
		<link rel="stylesheet" href="/assets/css/vendor/fontawesome.css" />
		<link rel="stylesheet" href="/assets/css/vendor/magnific-popup.css" />
		<link rel="stylesheet" href="/assets/css/vendor/mobile.css" />
		<link rel="stylesheet" href="/assets/css/vendor/owlcarousel.min.css" />
		<link rel="stylesheet" href="/assets/css/vendor/sidebar.css" />
		<link rel="stylesheet" href="/assets/css/vendor/slick-slider.css" />
		<link rel="stylesheet" href="/assets/css/vendor/nice-select.css" />
		<link rel="stylesheet" href="/assets/css/vendor/odometer.css" />
		<link rel="stylesheet" href="/assets/css/main.css" />
		<style>
			/* Ticket checkout overlay (Reserve a spot) */
			.ticket-checkout-overlay {
				position: fixed;
				inset: 0;
				z-index: 999;
				display: none;
			}
			.ticket-checkout-overlay.active {
				display: block;
			}
			.ticket-checkout-backdrop {
				position: absolute;
				inset: 0;
				background: rgba(0, 0, 0, 0.6);
			}
			.ticket-checkout-modal {
				position: relative;
				max-width: 920px;
				margin: 3rem auto;
				background: #fff;
				border-radius: 16px;
				box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
				overflow: hidden;
				display: flex;
				flex-direction: row;
				min-height: 420px;
			}
			@media (max-width: 991px) {
				.ticket-checkout-modal {
					margin: 1.5rem;
					flex-direction: column;
					min-height: auto;
				}
			}
			.ticket-checkout-main {
				flex: 2;
				padding: 1.75rem;
				border-right: 1px solid #f1f3f5;
			}
			.ticket-checkout-summary {
				flex: 1.4;
				padding: 1.75rem;
				background: #fafbff;
			}
			.ticket-checkout-thankyou {
				text-align: left;
			}
			.ticket-checkout-thankyou-icon {
				width: 32px;
				height: 32px;
				border-radius: 50%;
				background: #22c55e;
				color: #fff;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 0.75rem;
			}
			.ticket-summary-hero {
				border-radius: 12px;
				overflow: hidden;
				margin-bottom: 1rem;
				background: #e5e7eb;
				height: 140px;
			}
			.ticket-summary-hero img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.ticket-checkout-header-title {
				font-size: 1.15rem;
				font-weight: 700;
				margin-bottom: 0.25rem;
			}
			.ticket-checkout-header-subtitle {
				font-size: 0.85rem;
				color: #6c757d;
				margin-bottom: 1rem;
			}
			.ticket-checkout-card {
				border-radius: 12px;
				border: 1px solid #d0d7ff;
				padding: 1rem 1.25rem;
				background: #fff;
				box-shadow: 0 0 0 2px rgba(46, 77, 253, 0.04);
			}
			.ticket-checkout-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.5rem 0;
				border-bottom: 1px solid #f1f3f5;
			}
			.ticket-checkout-row:last-child {
				border-bottom: none;
			}
			.ticket-name {
				font-weight: 600;
				font-size: 0.95rem;
			}
			.ticket-meta {
				font-size: 0.8rem;
				color: #6c757d;
			}
			.ticket-price {
				font-size: 0.9rem;
				font-weight: 500;
			}
			.ticket-qty-control {
				display: inline-flex;
				align-items: center;
				border-radius: 999px;
				border: 1px solid #d0d7ff;
				overflow: hidden;
				background: #f8f9ff;
			}
			.ticket-qty-btn {
				width: 28px;
				height: 28px;
				border: none;
				background: transparent;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				font-size: 0.9rem;
				cursor: pointer;
				color: #1f2933;
			}
			.ticket-qty-value {
				min-width: 32px;
				text-align: center;
				font-size: 0.9rem;
				font-weight: 500;
				color: #111827;
			}
			.ticket-checkout-footer {
				margin-top: 1.25rem;
				display: flex;
				justify-content: flex-end;
			}
			.ticket-summary-line {
				display: flex;
				justify-content: space-between;
				font-size: 0.9rem;
				margin-bottom: 0.25rem;
			}
			.ticket-summary-total {
				display: flex;
				justify-content: space-between;
				font-weight: 700;
				margin-top: 0.75rem;
				padding-top: 0.75rem;
				border-top: 1px solid #e5e7eb;
			}
			.ticket-checkout-close {
				position: absolute;
				top: 0.75rem;
				right: 0.9rem;
				border: none;
				background: transparent;
				font-size: 1.2rem;
				cursor: pointer;
				color: #4b5563;
			}
		</style>
		<script src="/assets/js/vendor/jquery-3.7.1.min.js"></script>
	</head>
	<body class="homepage1-body">
		<div id="popup" class="popup-overlay d-none"></div>
		<div class="preloader">
			<div class="loading-container">
				<div class="loading"></div>
				<div id="loading-icon"><img src="/assets/img/logo/preloader.png" alt="" /></div>
			</div>
		</div>
		<div class="paginacontainer">
			<div class="progress-wrap">
				<svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
					<path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
				</svg>
			</div>
		</div>

		<header>
			<div class="header-area homepage1 header header-sticky d-none d-lg-block" id="header">
				<div class="container">
					<div class="row">
						<div class="col-lg-12">
							<div class="header-elements">
								<div class="site-logo">
									<a href="{{ path('app_home') }}"><img src="/assets/img/logo/logo1.png" alt="" /></a>
								</div>
								<div class="main-menu">
									<ul>
										<li><a href="{{ path('app_home') }}">Home</a></li>
										<li>
											<a href="#">Events <i class="fa-solid fa-angle-down"></i></a>
											<ul class="dropdown-padding">
												<li><a href="{{ path('app_events') }}">Events</a></li>
												<li><a href="{{ path('app_event_create') }}">Create Events</a></li>
											</ul>
										</li>
										<li><a href="about.html">About Event</a></li>
										<li><a href="contact.html">Contact Us</a></li>
									</ul>
								</div>
								<div class="btn-area">
									<ul>
										<li><a href="#"><i class="fa-brands fa-facebook-f"></i></a></li>
										<li><a href="#"><i class="fa-brands fa-instagram"></i></a></li>
										<li><a href="#"><i class="fa-brands fa-linkedin-in"></i></a></li>
									</ul>
								</div>
								<div class="body-overlay"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</header>

		<div class="mobile-header mobile-haeder1 d-block d-lg-none">
			<div class="container-fluid">
				<div class="col-12">
					<div class="mobile-header-elements">
						<div class="mobile-logo">
							<a href="{{ path('app_home') }}"><img src="/assets/img/logo/logo1.png" alt="" /></a>
						</div>
						<div class="mobile-nav-icon dots-menu"><i class="fa-solid fa-bars-staggered"></i></div>
					</div>
				</div>
			</div>
		</div>
		<div class="mobile-sidebar mobile-sidebar1">
			<div class="logosicon-area">
				<div class="logos"><img src="/assets/img/logo/logo2.png" alt="" /></div>
				<div class="menu-close"><i class="fa-solid fa-xmark"></i></div>
			</div>
			<div class="mobile-nav mobile-nav1">
				<ul class="mobile-nav-list nav-list1">
					<li><a href="{{ path('app_home') }}">Home</a></li>
					<li><a href="{{ path('app_events') }}">Events</a></li>
					<li><a href="contact.html">Contact Us</a></li>
				</ul>
			</div>
		</div>

		{# ----- EVENT HERO BANNER ----- #}
		<div class="inner-page-header position-relative" style="min-height: 380px; background-image: url({{ event.image ?: '/assets/img/bg/header-bg6.png' }}); background-size: cover; background-position: center;">
			<div class="position-absolute w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%); top: 0; left: 0;"></div>
			<div class="container position-relative" style="z-index: 2;">
				<div class="row align-items-end" style="min-height: 380px; padding-bottom: 2rem;">
					<div class="col-lg-12">
						<h1 class="text-white mb-2" style="font-size: 2.5rem; font-weight: 700;">{{ event.title }}</h1>
						<p class="text-white mb-1">
							{% if event.startDatetime %}
								{{ event.startDatetime|date('d M Y') }}
							{% endif %}
							{% if event.venue %}
								<span class="ms-3"><i class="fa-solid fa-location-dot me-1"></i>{{ event.venue.name }}</span>
							{% endif %}
						</p>
						<a href="{{ path('app_home') }}" class="text-white small">Home <i class="fa-solid fa-angle-right"></i> <span>{{ event.title }}</span></a>
					</div>
				</div>
			</div>
		</div>

		{# ----- EVENT DETAIL CONTENT ----- #}
		<div class="container py-5">
			<div class="row">
				<div class="col-lg-8">
					<h2 class="h3 fw-bold mb-3">{{ event.title }}</h2>
					{% if event.organizer %}
						<p class="text-muted mb-2">
							By {{ event.organizer.name }}
							<button type="button" class="btn btn-sm btn-outline-secondary border ms-2">Follow</button>
						</p>
					{% endif %}
					{% if event.venue %}
						<p class="text-muted mb-1"><i class="fa-solid fa-location-dot me-2"></i>{{ event.venue.name }}{% if event.venue.city %} • {{ event.venue.city }}{% if event.venue.country %}, {{ event.venue.country }}{% endif %}{% endif %}</p>
					{% endif %}
					<p class="text-muted mb-4">
						<i class="fa-solid fa-calendar me-2"></i>
						{% if event.startDatetime and event.endDatetime %}
							{{ event.startDatetime|date('l, M d') }} from {{ event.startDatetime|date('g a') }} to {{ event.endDatetime|date('g a') }}
						{% elseif event.startDatetime %}
							{{ event.startDatetime|date('l d F Y, H:i') }}
						{% endif %}
					</p>

					<h3 class="h5 fw-bold mt-4 mb-2">Overview</h3>
					<div class="mb-4">{{ event.description|nl2br }}</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Good to know</h3>
					<div class="border rounded p-3 mb-4 shadow-sm">
						<p class="mb-1 text-muted"><i class="fa-regular fa-clock me-2"></i>{% if event.startDatetime and event.endDatetime %}{% set diff = event.endDatetime.diff(event.startDatetime) %}{{ diff.days * 24 + diff.h }} hours{% else %}—{% endif %}</p>
						<p class="mb-0 text-muted"><i class="fa-solid fa-location-dot me-2"></i>{% if event.venue %}In person{% else %}Online / TBA{% endif %}</p>
					</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Location</h3>
					{% if event.venue %}
						<p class="fw-bold mb-1">{{ event.venue.name }}</p>
						<p class="text-muted mb-3">{% if event.venue.address %}{{ event.venue.address }}{% endif %}{% if event.venue.city %} {{ event.venue.city }}{% endif %}{% if event.venue.state %} {{ event.venue.state }}{% endif %}{% if event.venue.postalCode %} {{ event.venue.postalCode }}{% endif %}</p>
						<div class="border rounded bg-light mb-4 d-flex align-items-center justify-content-center" style="height: 200px;">
							<button type="button" class="btn btn-outline-secondary">Show map</button>
						</div>
					{% else %}
						<p class="text-muted mb-4">Location to be announced.</p>
					{% endif %}

					<h3 class="h5 fw-bold mt-4 mb-2">How do you want to get there?</h3>
					<div class="d-flex flex-wrap gap-2 mb-4">
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-car me-1"></i>Driving</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-bus me-1"></i>Public transport</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-bicycle me-1"></i>Biking</button>
						<button type="button" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-person-walking me-1"></i>Walking</button>
					</div>

					<h3 class="h5 fw-bold mt-4 mb-2">Organized by</h3>
					{% if event.organizer %}
						<div class="border rounded p-3 mb-3 shadow-sm d-flex align-items-center flex-wrap">
							<div class="rounded-circle bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center me-3" style="width: 56px; height: 56px;">
								<span class="fw-bold text-secondary">{{ event.organizer.name|slice(0, 2)|upper }}</span>
							</div>
							<div class="flex-grow-1">
								<p class="fw-bold mb-1">{{ event.organizer.name }}</p>
								<p class="small text-muted mb-0">Events · Organizer</p>
							</div>
							<div>
								<button type="button" class="btn btn-outline-secondary btn-sm me-1">Contact</button>
								<button type="button" class="btn btn-sm vl-btn4">Follow</button>
							</div>
						</div>
					{% endif %}
					<p class="small"><a href="#" class="text-primary"><i class="fa-regular fa-flag me-1"></i>Report this event</a></p>

					{% if otherEvents|length > 0 %}
						<h3 class="h5 fw-bold mt-5 mb-3">Other events you may like</h3>
						<ul class="list-unstyled">
							{% for other in otherEvents %}
								<li class="border-bottom py-3 d-flex align-items-center">
									<div class="flex-grow-1">
										<a href="{{ path('app_event_show', { id: other.id }) }}" class="fw-bold text-dark text-decoration-none">{{ other.title }}</a>
										<p class="small text-muted mb-0">
											{% if other.startDatetime %}{{ other.startDatetime|date('D, d M') }} · {{ other.startDatetime|date('H:i') }}{% endif %}
											{% if other.venue %} · {{ other.venue.name }}{% endif %}
										</p>
										<p class="small text-muted mb-0">{{ other.priceLabel }}</p>
									</div>
									<a href="{{ path('app_event_show', { id: other.id }) }}" class="btn btn-sm vl-btn4">Reserve a spot</a>
								</li>
							{% endfor %}
						</ul>
					{% endif %}
				</div>

				<div class="col-lg-4">
					<div class="position-sticky" style="top: 100px;">
						<div class="border rounded p-4 shadow-sm bg-white">
							<div class="d-flex justify-content-end gap-2 mb-3">
								<button type="button" class="btn btn-link btn-sm text-dark p-0"><i class="fa-solid fa-arrow-up-from-bracket"></i></button>
								<button type="button" class="btn btn-link btn-sm text-dark p-0"><i class="fa-regular fa-heart"></i></button>
							</div>
							<p class="h5 fw-bold mb-1">{{ event.priceLabel }}</p>
							<p class="text-muted small mb-3">{% if event.startDatetime %}{{ event.startDatetime|date('M d') }} · {{ event.startDatetime|date('g:i a') }}{% endif %}</p>
							<button type="button" class="btn vl-btn4 w-100 mb-2" id="open-ticket-checkout">Reserve a spot</button>
							{% if is_granted('EVENT_EDIT', event) %}
							<div class="pt-3 border-top mt-3">
								<a href="{{ path('app_orders_event', { id: event.id }) }}" class="btn btn-outline-primary btn-sm me-1">View orders</a>
								<a href="{{ path('app_event_edit', { id: event.id }) }}" class="btn btn-outline-secondary btn-sm me-1">Edit</a>
								<form method="post" action="{{ path('app_event_delete', { id: event.id }) }}" class="d-inline" onsubmit="return confirm('Delete this event?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}" />
									<button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
								</form>
							</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ----- TICKET CHECKOUT MODAL ----- #}
		<div class="ticket-checkout-overlay" id="ticket-checkout"
			data-checkout-url="{{ path('app_order_checkout', { eventId: event.id }) }}"
			data-checkout-token="{{ csrf_token('order_checkout_' ~ event.id) }}">
			<div class="ticket-checkout-backdrop"></div>
			<div class="ticket-checkout-modal" role="dialog" aria-modal="true" aria-labelledby="ticket-checkout-title">
				<button type="button" class="ticket-checkout-close" id="ticket-checkout-close" aria-label="Close checkout">&times;</button>
				<div class="ticket-checkout-main">
					{# Step 1: select tickets #}
					<div class="ticket-step ticket-step-1" id="ticket-step-1">
						<div class="ticket-checkout-header mb-3">
							<div class="ticket-checkout-header-title" id="ticket-checkout-title">{{ event.title }}</div>
							<div class="ticket-checkout-header-subtitle">
								{% if event.startDatetime %}{{ event.startDatetime|date('l, F j \\· g a') }}{% endif %}
							</div>
						</div>
						<div class="ticket-checkout-card">
							{% if event.tickets|length > 0 %}
								{% for ticket in event.tickets %}
									<div class="ticket-checkout-row" data-ticket-id="{{ ticket.id }}" data-ticket-name="{{ ticket.name }}" data-ticket-price="{{ ticket.price }}">
										<div class="me-3">
											<div class="ticket-name">{{ ticket.name }}</div>
											<div class="ticket-price">
												{% if ticket.price == '0' or ticket.price == '0.00' %}
													Free
												{% else %}
													${{ ticket.price }}
												{% endif %}
											</div>
											<div class="ticket-meta">
												{% if ticket.saleEnd %}Sales end {{ ticket.saleEnd|date('M j, Y') }}{% endif %}
											</div>
										</div>
										<div class="ticket-qty-control" aria-label="Quantity for {{ ticket.name }}">
											<button type="button" class="ticket-qty-btn ticket-qty-minus" aria-label="Decrease quantity">-</button>
											<span class="ticket-qty-value">0</span>
											<button type="button" class="ticket-qty-btn ticket-qty-plus" aria-label="Increase quantity">+</button>
										</div>
									</div>
								{% endfor %}
							{% else %}
								<p class="mb-0 small text-muted">No tickets are available for this event yet.</p>
							{% endif %}
						</div>
						<div class="ticket-checkout-footer">
							<button type="button" class="btn vl-btn4" id="ticket-checkout-continue">Register</button>
						</div>
					</div>

					{# Step 2: contact information #}
					<div class="ticket-step ticket-step-2 d-none" id="ticket-step-2">
						<div class="d-flex align-items-center mb-3">
							<button type="button" class="btn btn-link btn-sm px-0 me-2" id="ticket-step2-back"><i class="fa-solid fa-arrow-left me-1"></i> Back</button>
							<h2 class="h6 fw-bold mb-0">Checkout</h2>
						</div>
						<p class="small text-muted mb-3">Contact information</p>
						{% if is_granted('IS_AUTHENTICATED_FULLY') and app.user %}
							<p class="small text-muted mb-2">Logged in as <strong>{{ app.user.email }}</strong>. Not you? <a href="{{ path('app_logout') }}">Log out</a></p>
						{% endif %}
						<form id="ticket-contact-form">
							<div class="row mb-3">
								<div class="col-md-6">
									<label class="form-label small">First name *</label>
									<input type="text" class="form-control form-control-sm" name="firstName" value="{{ app.user.firstName ?? '' }}" required />
								</div>
								<div class="col-md-6">
									<label class="form-label small">Last name *</label>
									<input type="text" class="form-control form-control-sm" name="lastName" value="{{ app.user.lastName ?? '' }}" required />
								</div>
							</div>
							<div class="mb-3">
								<label class="form-label small">Email address *</label>
								<input type="email" class="form-control form-control-sm" name="email" value="{{ app.user.email ?? '' }}" required />
							</div>
							<div class="form-check mb-1">
								<input class="form-check-input" type="checkbox" value="1" id="ticket-optin-organizer" checked />
								<label class="form-check-label small" for="ticket-optin-organizer">
									Keep me updated on more events and news from this event organizer.
								</label>
							</div>
							<div class="form-check mb-3">
								<input class="form-check-input" type="checkbox" value="1" id="ticket-optin-platform" />
								<label class="form-check-label small" for="ticket-optin-platform">
									Send me emails about the best events happening nearby or online.
								</label>
							</div>
							<p class="small text-muted mb-3">By selecting Register, I agree to the terms of service and privacy policy.</p>
							<div class="ticket-checkout-footer">
								<button type="submit" class="btn vl-btn4" id="ticket-checkout-register">Register</button>
							</div>
						</form>
					</div>

					{# Step 3: thank you page #}
					<div class="ticket-step ticket-step-3 d-none" id="ticket-step-3">
						<div class="ticket-checkout-thankyou">
							<div class="ticket-checkout-thankyou-icon mb-2">
								<i class="fa-solid fa-check" aria-hidden="true"></i>
							</div>
							<h2 class="h5 fw-bold mb-1">Thanks for your order!</h2>
							<p class="small text-muted mb-2" id="ticket-thankyou-order-id"></p>
