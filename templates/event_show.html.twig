							<h2 class="fw-bold mb-2" style="font-size: 1.75rem; color: #1f2937;">Order Confirmed!</h2>
							<p class="small text-muted mb-2" id="ticket-thankyou-order-id"></p>
							<p class="small text-muted mb-3">You're going to <strong>{{ event.title }}</strong>.</p>
							<div class="mb-3">
								<div class="small text-muted text-uppercase mb-1">Ticket sent to</div>
								<div class="fw-semibold small" id="ticket-thankyou-email"></div>
							</div>
							<div class="mb-3" id="ticket-thankyou-qr-wrapper" style="display: none;">
								<div class="small text-muted text-uppercase mb-1">Your ticket QR code</div>
								<img id="ticket-thankyou-qr" src="" alt="Ticket QR code" style="width: 150px; height: 150px; object-fit: contain; border-radius: 8px; border: 1px solid #e5e7eb; padding: 4px; background: #fff;">
							</div>
							<div class="row g-3 mb-3">
