								</div>
							</div>
							<div class="d-flex flex-column gap-2 mt-4">
								<a href="{{ path('app_orders_index') }}" class="btn btn-primary btn-lg" style="border-radius: 10px; font-weight: 600;"><i class="fa-solid fa-ticket me-2"></i>View My Tickets</a>
								<button type="button" class="btn btn-outline-secondary" id="ticket-thankyou-close" style="border-radius: 10px;">Back to Event</button>
							</div>
