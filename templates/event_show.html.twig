		<script>
			function hidePreloader() {
				$('.preloader').fadeOut(300);
			}
			$(window).on('load', function() {
				setTimeout(hidePreloader, 200);
			});
			setTimeout(hidePreloader, 2500);

			// Sponsor request modal
			$(function() {
				var $sponsorModal = $('#sponsor-request-modal');
				var $sponsorForm = $('#sponsor-request-form');
				if ($sponsorModal.length && $sponsorForm.length) {
					$('.sponsor-request-btn').on('click', function() {
						var url = $(this).data('submit-url');
						var name = $(this).data('package-name');
						$sponsorForm.attr('action', url);
						$('#sponsor-modal-package-name').text(name);
						$sponsorModal.css('display', 'flex');
					});
					function closeSponsorModal() {
						$sponsorModal.css('display', 'none');
					}
					$('#sponsor-request-close, #sponsor-request-cancel').on('click', closeSponsorModal);
					$sponsorModal.on('click', function(e) {
						if (e.target === $sponsorModal[0]) closeSponsorModal();
					});
				}
			});

			// Ticket checkout modal logic
			$(function() {
				var $overlay = $('#ticket-checkout');
				var $openBtn = $('#open-ticket-checkout');
				var $closeBtn = $('#ticket-checkout-close');
				var $backdrop = $('.ticket-checkout-backdrop');

				function recalcSummary() {
					var $lines = $('#ticket-summary-lines');
					var total = 0;
					$lines.empty();
					$('.ticket-checkout-row').each(function() {
						var $row = $(this);
						var qty = parseInt($row.find('.ticket-qty-value').text(), 10) || 0;
						if (!qty) return;
						var name = $row.data('ticket-name');
						var priceStr = $row.data('ticket-price');
						var price = parseFloat(priceStr || '0');
						var lineTotal = price * qty;
						if (!isNaN(lineTotal)) total += lineTotal;
						var labelPrice = price === 0 ? 'Free' : '$' + price.toFixed(2);
						var $line = $('<div class=\"ticket-summary-line\"></div>');
						$line.append('<span>' + qty + ' × ' + name + '</span>');
						$line.append('<span>' + labelPrice + '</span>');
						$lines.append($line);
					});
					var totalLabel = total === 0 ? '$0.00' : '$' + total.toFixed(2);
					$('#ticket-summary-total-amount').text(totalLabel);
				}

				function openOverlay() {
					if (!$overlay.length) return;
					$overlay.addClass('active');
					recalcSummary();
					$('#ticket-step-1').removeClass('d-none');
					$('#ticket-step-2').addClass('d-none');
					$('#ticket-step-3').addClass('d-none');
					$('#ticket-checkout-register').prop('disabled', false).text('Register');
				}
				function closeOverlay() {
					$overlay.removeClass('active');
				}

				$openBtn.on('click', function(e) {
					e.preventDefault();
					openOverlay();
				});
				$closeBtn.on('click', function() {
					closeOverlay();
				});
				$backdrop.on('click', function() {
					closeOverlay();
				});

				$(document).on('click', '.ticket-qty-plus', function() {
					var $val = $(this).siblings('.ticket-qty-value');
					var current = parseInt($val.text(), 10) || 0;
					$val.text(current + 1);
					recalcSummary();
				});
				$(document).on('click', '.ticket-qty-minus', function() {
					var $val = $(this).siblings('.ticket-qty-value');
					var current = parseInt($val.text(), 10) || 0;
					if (current > 0) {
						$val.text(current - 1);
						recalcSummary();
					}
				});

				// Step 1 -> Step 2 transition (allow free events: total can be $0.00 if at least one ticket qty > 0)
				$('#ticket-checkout-continue').on('click', function () {
					var hasSelection = false;
					$('.ticket-checkout-row').each(function() {
						var qty = parseInt($(this).find('.ticket-qty-value').text(), 10) || 0;
						if (qty > 0) { hasSelection = true; }
					});
					if (!hasSelection) {
						alert('Please select at least one ticket.');
						return;
					}
					$('#ticket-step-1').addClass('d-none');
					$('#ticket-step-2').removeClass('d-none');
				});

				$('#ticket-step2-back').on('click', function () {
					$('#ticket-step-2').addClass('d-none');
					$('#ticket-step-1').removeClass('d-none');
				});

				// Final step: create Stripe Checkout Session (or free order) then redirect to Stripe or show thank-you
				$('#ticket-contact-form').on('submit', function (e) {
					e.preventDefault();
					var $form = $(this);
					var $btn = $('#ticket-checkout-register');
					var email = $form.find('input[name=\"email\"]').val() || '';
					var url = $overlay.data('checkout-url');
					var eventId = $overlay.data('event-id');
					var token = $overlay.data('checkout-token');
					var items = [];
					$('.ticket-checkout-row').each(function() {
						var $row = $(this);
						var qty = parseInt($row.find('.ticket-qty-value').text(), 10) || 0;
						if (qty > 0) {
							items.push({
								ticketId: parseInt($row.data('ticket-id'), 10),
								quantity: qty
							});
						}
					});
					if (items.length === 0) {
						alert('Please select at least one ticket.');
						return;
					}
					$btn.prop('disabled', true).text('Processing…');
					$.ajax({
						url: url,
						method: 'POST',
						contentType: 'application/json',
						data: JSON.stringify({ _token: token, eventId: eventId, items: items }),
						success: function (data) {
							if (!data || typeof data !== 'object') {
								$btn.prop('disabled', false).text('Proceed to payment');
								alert('Invalid response from server. Please try again.');
								return;
							}
							if (data.url) {
								window.location.href = data.url;
								return;
							}
							if (data.skipStripe && data.success) {
								$('#ticket-thankyou-email').text(email);
								var orderId = data.orderId || (data.orders && data.orders[0] && data.orders[0].id);
								$('#ticket-thankyou-order-id').text(orderId ? 'Order #' + orderId : '').toggle(!!orderId);
								if (data.qrCodeUrl || data.qrCodePath) {
									var src = data.qrCodeUrl || (data.qrCodePath.charAt(0) === '/' ? data.qrCodePath : '/' + data.qrCodePath);
									$('#ticket-thankyou-qr').attr('src', src);
									$('#ticket-thankyou-qr-wrapper').show();
								} else {
									$('#ticket-thankyou-qr-wrapper').hide();
								}
								$('#ticket-step-2').addClass('d-none');
								$('#ticket-step-3').removeClass('d-none');
							} else {
								$btn.prop('disabled', false).text('Proceed to payment');
								alert(data.error || 'Unable to complete registration.');
							}
						},
						error: function (xhr) {
							$btn.prop('disabled', false).text('Proceed to payment');
							var msg = 'Unable to complete registration.';
							if (xhr.status === 401) {
								msg = 'Please log in to complete your order.';
								window.location.href = xhr.responseJSON && xhr.responseJSON.login_url
									? xhr.responseJSON.login_url
									: '{{ path('app_login') }}?redirect=' + encodeURIComponent(window.location.href);
								return;
							}
							try {
								var data = xhr.responseJSON || (xhr.responseText ? JSON.parse(xhr.responseText) : null);
								if (data && data.error) msg = data.error;
							} catch (e) {}
							alert(msg);
						}
					});
				});

				$('#ticket-thankyou-close').on('click', function () {
					closeOverlay();
				});
			});

			// Share event functionality
			$(function() {
				$('#share-event-btn').on('click', function() {
					var eventTitle = '{{ event.title|e('js') }}';
					var eventUrl = window.location.href;
					var eventDescription = '{{ event.description|default('')|slice(0, 100)|e('js') }}';

					// Check if Web Share API is supported
					if (navigator.share) {
						navigator.share({
							title: eventTitle,
							text: eventDescription,
							url: eventUrl
						}).then(function() {
							console.log('Event shared successfully');
						}).catch(function(err) {
							console.log('Error sharing:', err);
						});
					} else {
						// Fallback: Copy to clipboard
						var tempInput = document.createElement('input');
						tempInput.value = eventUrl;
						document.body.appendChild(tempInput);
						tempInput.select();
						tempInput.setSelectionRange(0, 99999);
						
						try {
							document.execCommand('copy');
							document.body.removeChild(tempInput);
							
							// Show success message
							var $btn = $(this);
							var originalHTML = $btn.html();
							$btn.html('<i class="fa-solid fa-check"></i>');
							$btn.addClass('btn-success').removeClass('btn-outline-secondary');
							
							setTimeout(function() {
								$btn.html(originalHTML);
								$btn.removeClass('btn-success').addClass('btn-outline-secondary');
							}, 2000);
						} catch (err) {
							alert('Could not copy link. Please copy manually: ' + eventUrl);
							document.body.removeChild(tempInput);
						}
					}
				});
			});
		</script>
	</body>
