		<script>
		(function () {
			var container = document.getElementById('events-list-container');
			var heroSearchEl = document.getElementById('hero-search');
			var heroSearchBtn = heroSearchEl ? heroSearchEl.nextElementSibling : null;
			if (!container || !heroSearchEl) return;

			var debounceTimer;
			function debounce(fn, ms) {
				return function () {
					clearTimeout(debounceTimer);
					var self = this, args = arguments;
					debounceTimer = setTimeout(function () { fn.apply(self, args); }, ms);
				};
			}

			function loadEvents() {
				var q = heroSearchEl.value ? heroSearchEl.value.trim() : '';
				var sort = 'date_asc'; // Default sort
				var params = new URLSearchParams();
				if (q) params.set('q', q);
				params.set('sort', sort);
				var url = (window.location.pathname || '/events') + '?' + params.toString();

				container.style.opacity = '0.6';
				container.style.pointerEvents = 'none';

				fetch(url, {
					headers: { 'X-Requested-With': 'XMLHttpRequest' }
				})
					.then(function (r) { return r.text(); })
					.then(function (html) {
						container.innerHTML = html;
						history.replaceState(null, '', url);
					})
					.catch(function () {
						container.innerHTML = '<div class="col-12 text-center py-5"><p class="text-danger">Error loading events. Please refresh.</p></div>';
					})
					.finally(function () {
						container.style.opacity = '';
						container.style.pointerEvents = '';
					});
			}

			// Hero search on input - filter without scrolling
			heroSearchEl.addEventListener('input', debounce(function() {
				loadEvents();
			}, 350));

			// Handle search button click - filter and scroll
			if (heroSearchBtn) {
				heroSearchBtn.addEventListener('click', function() {
					loadEvents();
					// Scroll to events section
					var eventsSection = document.querySelector('.team-sperkers-section-area');
					if (eventsSection) {
						eventsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}
				});
			}

			// Handle Enter key on hero search - filter and scroll
			heroSearchEl.addEventListener('keypress', function(e) {
				if (e.key === 'Enter') {
					loadEvents();
					// Scroll to events section
					var eventsSection = document.querySelector('.team-sperkers-section-area');
					if (eventsSection) {
						eventsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}
				}
			});
		})();
		</script>
