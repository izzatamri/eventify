		<!--===== EVENTS AREA STARTS =======-->
		<div class="team-sperkers-section-area sp1">
			<div class="container">
				{% for message in app.flashes('success') %}
					<div class="alert alert-success" role="alert">{{ message }}</div>
				{% endfor %}
				{% for message in app.flashes('error') %}
					<div class="alert alert-danger" role="alert">{{ message }}</div>
				{% endfor %}
				<div class="row">
					{% for event in events %}
						<div class="col-lg-3 col-md-6 mb-4">
							<div class="event-card border rounded overflow-hidden bg-white h-100 d-flex flex-column">
								<a href="{{ path('app_event_show', { id: event.id }) }}" class="text-decoration-none text-dark">
									<div class="event-card-image position-relative" style="height: 180px; background: #e9ecef;">
										{% if event.image %}
											<img src="{{ event.image }}" alt="{{ event.title }}" class="w-100 h-100" style="object-fit: cover;" />
										{% else %}
											<div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
												<i class="fa-solid fa-calendar-days fa-3x"></i>
											</div>
										{% endif %}
										<div class="position-absolute top-0 start-0 p-2 d-flex flex-wrap gap-1">
											{% if event.createdAt and date().diff(event.createdAt).days < 7 %}
												<span class="badge bg-success">Just added</span>
											{% endif %}
											{% if event.status == 'published' %}
												<span class="badge bg-primary">Published</span>
											{% elseif event.status == 'draft' %}
												<span class="badge bg-secondary">Draft</span>
											{% elseif event.status == 'cancelled' %}
												<span class="badge bg-danger">Cancelled</span>
											{% endif %}
										</div>
									</div>
									<div class="event-card-body p-3 flex-grow-1 d-flex flex-column">
										<h3 class="h6 fw-bold mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3;">{{ event.title }}</h3>
										<p class="small text-muted mb-1">
											{% if event.startDatetime %}
												{{ event.startDatetime|date('l') }} • {{ event.startDatetime|date('g:i A') }}
											{% endif %}
										</p>
										<p class="small text-muted mb-2">
											{% if event.venue %}
												{{ event.venue.name }}
											{% elseif event.organizer %}
												{{ event.organizer.name }}
											{% else %}
												&nbsp;
											{% endif %}
										</p>
										<p class="small fw-semibold mb-0 mt-auto">{{ event.priceLabel }}</p>
									</div>
								</a>
								<div class="event-card-actions p-3 border-top bg-light d-flex flex-wrap gap-1">
									<a href="{{ path('app_event_show', { id: event.id }) }}" class="btn btn-sm btn-outline-primary">View</a>
									{% if is_granted('EVENT_EDIT', event) %}
									<a href="{{ path('app_event_edit', { id: event.id }) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
									<form method="post" action="{{ path('app_event_delete', { id: event.id }) }}" class="d-inline" onsubmit="return confirm('Delete this event?');">
										<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}" />
										<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
									</form>
									{% endif %}
								</div>
							</div>
						</div>
					{% else %}
						<div class="col-12 text-center py-5">
							<p class="text-muted">No events yet.</p>
							<a href="{{ path('app_event_create') }}" class="vl-btn4">Create your first event</a>
						</div>
					{% endfor %}
				</div>
			</div>
