{% extends 'base.html.twig' %}

{% block title %}Access Denied - Eventify{% endblock %}

{% block body %}
<div class="inner-page-header" style="background-image: url(/assets/img/bg/header-bg6.png); padding: 80px 0 60px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <h1 style="font-size: 42px; margin-bottom: 15px; color: #fff;">Access Denied</h1>
                <p style="font-size: 16px; color: rgba(255,255,255,0.9);">You don't have permission to edit this event</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0" style="border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="fa-solid fa-lock" style="font-size: 64px; color: #dc3545;"></i>
                    </div>
                    <h2 class="fw-bold mb-3" style="font-size: 24px; color: #1f2937;">You Cannot Edit This Event</h2>
                    <p class="text-muted mb-4">
                        Only the event creator can edit their event. If you believe this is an error, please contact the event organizer.
                    </p>
                    <div class="d-flex flex-column gap-2">
                        <a href="{{ path('app_events') }}" class="btn btn-primary" style="border-radius: 8px; font-weight: 600;">
                            <i class="fa-solid fa-arrow-left me-2"></i>Browse All Events
                        </a>
                        <a href="{{ path('app_my_events') }}" class="btn btn-outline-secondary" style="border-radius: 8px;">
                            <i class="fa-solid fa-calendar me-2"></i>My Events
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
